---
import Layout from "../layouts/Layout.astro";
import Cover from "../components/Cover.astro";
import About from "../components/About.astro";
import Categories from "../components/Categories.astro";
import MostPopular from "../components/MostPopular.astro";

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Coronado Gold",
  "url": "https://goldcoronado.com",
  "logo": "https://goldcoronado.com/logo.svg",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+17863677012",
    "email": "coronadogoldjewelry@gmail.com",
    "contactType": "customer service"
  },
  "sameAs": [
    "https://www.instagram.com/coronado.gold",
    "https://www.facebook.com/coronadogold"
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "49 W 3rd St",
    "addressLocality": "Hialeah",
    "addressRegion": "FL",
    "postalCode": "33010",
    "addressCountry": "US"
  }
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Coronado Gold",
  "url": "https://goldcoronado.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://goldcoronado.com/category/rings/?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "JewelryStore",
  "name": "Coronado Gold",
  "url": "https://goldcoronado.com",
  "logo": "https://goldcoronado.com/logo.svg",
  "image": "https://goldcoronado.com/og-image.jpg",
  "telephone": "+17863677012",
  "email": "coronadogoldjewelry@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "49 W 3rd St",
    "addressLocality": "Hialeah",
    "addressRegion": "FL",
    "postalCode": "33010",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 25.8576,
    "longitude": -80.2781
  },
  "sameAs": [
    "https://www.instagram.com/coronado.gold",
    "https://www.facebook.com/coronadogold"
  ],
  "priceRange": "$$",
  "currenciesAccepted": "USD",
  "paymentAccepted": "Credit Card, Cash",
  "hasMap": "https://maps.app.goo.gl/saCvgTfbbfDyzSBWA"
};
---

<Layout
  title="Fine Gold Jewelry — Rings & Necklaces"
  description="Discover Coronado Gold's fine gold jewelry — handcrafted rings and necklaces in 14k and 18k gold. Crafted with precision and elegance. Shop online."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  </Fragment>

  <main class="min-h-screen relative">
    <!-- Visually hidden H1 for SEO: screen readers and Googlebot see it -->
    <h1 class="sr-only">Coronado Gold — Fine Gold Jewelry | Handcrafted Rings & Necklaces</h1>
    <Cover />
    <About />
    <Categories />
    <MostPopular />
  </main>
</Layout>

<script>
  // ─── Scroll Snap para la página principal ────────────────────────────────────
  // Funciona junto a Lenis: interceptamos los eventos de rueda/touch/teclado,
  // evitamos el scroll nativo y usamos lenis.scrollTo() para el snap suavizado.

  const SECTION_IDS = ["#home", "#about", "#categories", "#most-popular"];
  const SNAP_DURATION = 1.0;     // segundos (para Lenis)
  const WHEEL_THRESHOLD = 30;    // px de delta para disparar el snap
  const WHEEL_RESET_MS = 200;    // ms sin rueda para resetear el acumulador
  const SNAP_SAFETY_MS = 1300;   // timeout máximo para desbloquear isSnapping

  function initScrollSnap() {
    const sections = SECTION_IDS
      .map((id) => document.querySelector<HTMLElement>(id))
      .filter((el): el is HTMLElement => el !== null);

    if (sections.length === 0) return;

    let isSnapping = false;
    let safetyTimer: ReturnType<typeof setTimeout> | null = null;
    let wheelDelta = 0;
    let wheelTimer: ReturnType<typeof setTimeout> | null = null;
    let touchStartY = 0;
    let touchStartX = 0;

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function getCurrentIndex(): number {
      const mid = window.scrollY + window.innerHeight * 0.4;
      let idx = 0;
      sections.forEach((s, i) => {
        if (s.offsetTop <= mid) idx = i;
      });
      return idx;
    }

    function isSideMenuOpen(): boolean {
      const menu = document.querySelector("#categories-side-menu");
      return menu !== null && !menu.classList.contains("-translate-x-full");
    }

    function isInFooterZone(): boolean {
      const last = sections[sections.length - 1];
      return window.scrollY > last.offsetTop + last.offsetHeight * 0.4;
    }

    function releaseSnap() {
      isSnapping = false;
      if (safetyTimer) { clearTimeout(safetyTimer); safetyTimer = null; }
      wheelDelta = 0; // descarta cualquier delta acumulado durante el snap
    }

    function snapTo(index: number) {
      if (isSnapping) return;
      if (index < 0 || index >= sections.length) return;

      isSnapping = true;
      wheelDelta = 0;

      // Timeout de seguridad: si onComplete nunca llega (Lenis interrumpido),
      // liberamos el bloqueo igualmente para evitar quedar atascados.
      safetyTimer = setTimeout(releaseSnap, SNAP_SAFETY_MS);

      const target = sections[index];
      const lenis = (window as any).__lenis;

      if (lenis) {
        lenis.scrollTo(target.offsetTop, {
          duration: SNAP_DURATION,
          easing: (t: number) => 1 - Math.pow(1 - t, 3),
          onComplete: releaseSnap,
        });
      } else {
        window.scrollTo({ top: target.offsetTop, behavior: "smooth" });
        setTimeout(releaseSnap, SNAP_DURATION * 1000 + 200);
      }
    }

    // ─── Wheel ────────────────────────────────────────────────────────────────
    // Usamos fase de CAPTURA (capture: true) para interceptar el evento ANTES
    // de que el listener de Lenis (registrado en fase de burbuja) lo reciba.
    // Solo bloqueamos cuando el destino es otra sección dentro del rango.
    // Si el nextIndex cae fuera del rango (ej. ir al footer), soltamos el
    // evento para que Lenis lo maneje con su scroll suavizado normal.

    function onWheel(e: WheelEvent) {
      if (isSideMenuOpen()) return;

      // Durante un snap en curso: bloquear siempre
      if (isSnapping) {
        e.preventDefault();
        e.stopImmediatePropagation();
        return;
      }

      const dir = e.deltaY > 0 ? 1 : -1;

      // Desde el footer scrolleando hacia arriba → volver a la última sección
      if (isInFooterZone()) {
        if (dir === -1) {
          e.preventDefault();
          e.stopImmediatePropagation();
          snapTo(sections.length - 1);
        }
        // dir === 1: dejar que Lenis scrollee más abajo en el footer
        return;
      }

      const nextIdx = getCurrentIndex() + dir;

      // Fuera del rango de secciones → liberar a Lenis (footer, o inicio)
      if (nextIdx < 0 || nextIdx >= sections.length) {
        wheelDelta = 0;
        return; // no llamamos preventDefault: Lenis recibe el evento
      }

      // Dentro del rango → interceptar y snap
      e.preventDefault();
      e.stopImmediatePropagation();

      wheelDelta += e.deltaY;
      if (wheelTimer) clearTimeout(wheelTimer);
      wheelTimer = setTimeout(() => { wheelDelta = 0; }, WHEEL_RESET_MS);

      if (Math.abs(wheelDelta) >= WHEEL_THRESHOLD) {
        snapTo(nextIdx);
      }
    }

    // ─── Touch ────────────────────────────────────────────────────────────────

    function onTouchStart(e: TouchEvent) {
      touchStartY = e.touches[0].clientY;
      touchStartX = e.touches[0].clientX;
    }

    function onTouchEnd(e: TouchEvent) {
      if (isSideMenuOpen() || isSnapping) return;
      const diffY = touchStartY - e.changedTouches[0].clientY;
      const diffX = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(diffY) < 50) return;
      if (Math.abs(diffX) > Math.abs(diffY)) return; // swipe horizontal → ignorar
      const dir = diffY > 0 ? 1 : -1;
      if (isInFooterZone()) {
        if (dir === -1) snapTo(sections.length - 1);
        return;
      }
      const nextIdx = getCurrentIndex() + dir;
      if (nextIdx < 0 || nextIdx >= sections.length) return;
      snapTo(nextIdx);
    }

    // ─── Teclado ──────────────────────────────────────────────────────────────

    function onKeyDown(e: KeyboardEvent) {
      if (isSideMenuOpen() || isSnapping) return;
      const tag = (e.target as HTMLElement)?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || (e.target as HTMLElement)?.isContentEditable) return;
      if (["ArrowDown", "PageDown", " "].includes(e.key)) {
        e.preventDefault();
        if (isInFooterZone()) return;
        snapTo(getCurrentIndex() + 1);
      } else if (["ArrowUp", "PageUp"].includes(e.key)) {
        e.preventDefault();
        if (isInFooterZone()) { snapTo(sections.length - 1); return; }
        snapTo(getCurrentIndex() - 1);
      }
    }

    // ─── Registro ─────────────────────────────────────────────────────────────

    // capture: true → nuestro handler corre ANTES que el listener de Lenis
    window.addEventListener("wheel", onWheel, { passive: false, capture: true });
    window.addEventListener("touchstart", onTouchStart, { passive: true });
    window.addEventListener("touchend", onTouchEnd, { passive: true });
    window.addEventListener("keydown", onKeyDown);

    // Limpieza al salir de la página
    window.addEventListener("beforeunload", () => {
      window.removeEventListener("wheel", onWheel, { capture: true } as any);
      window.removeEventListener("touchstart", onTouchStart);
      window.removeEventListener("touchend", onTouchEnd);
      window.removeEventListener("keydown", onKeyDown);
      if (safetyTimer) clearTimeout(safetyTimer);
    });
  }

  // Inicializar en carga inicial
  initScrollSnap();
</script>
