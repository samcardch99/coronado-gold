---
import CrystalButtonInterior from "../../components/helpers/CrystalButtonInterior.astro";
import Layout from "../../layouts/Layout.astro";
import Find from "../../assets/find.svg";
import CrystalButton from "../../components/helpers/CrystalButton.astro";
import Plus from "../../assets/plus-sign.svg";

// 1. Configuración de parámetros y rutas
export async function getStaticPaths() {
    return [
        {
            params: { category: "rings" },
            props: { title: "RINGS", handle: "rings" },
        },
        {
            params: { category: "necklaces" },
            props: { title: "NECKLACES", handle: "necklaces" },
        },
    ];
}

const { category } = Astro.params;
const { title, handle } = Astro.props;

// 2. Llamada a la Storefront API de Shopify
// Nota: Reemplaza con tus variables de entorno reales
const SHOPIFY_DOMAIN = import.meta.env.SHOPIFY_DOMAIN;
const STOREFRONT_ACCESS_TOKEN = import.meta.env.STOREFRONT_ACCESS_TOKEN;

const query = `
  query getProductsByCollection($handle: String!) {
    collection(handle: $handle) {
      products(first: 12) {
        edges {
          node {
            id
            title
            handle
            priceRange {
              minVariantPrice {
                amount
                currencyCode
              }
            }
            images(first: 1) {
              edges {
                node {
                  url
                  altText
                }
              }
            }
            variants(first: 1) {
              edges {
                node {
                  id
                  quantityAvailable
                }
              }
            }
            hoverImage: metafield(namespace: "custom", key: "hover_image") {
              reference {
                ... on MediaImage {
                  image {
                    url
                    altText
                  }
                }
              }
            }
          }
        }
      }
    }
  }
`;
console.log("DEBUG - Parámetro categoría:", category);
console.log("DEBUG - Variable handle que enviaré:", handle);
const handleToSend = String(handle).trim();

const response = await fetch(
    `https://${SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
    {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "X-Shopify-Storefront-Access-Token": STOREFRONT_ACCESS_TOKEN,
        },
        body: JSON.stringify({
            query,
            variables: {
                handle: handleToSend,
            },
        }),
    },
);

const json = await response.json();

if (json.errors) {
    console.error(
        "Error detallado de Shopify:",
        JSON.stringify(json.errors, null, 2),
    );
}

const products = json.data?.collection?.products?.edges || [];
---

<Layout title={title}>
    <main
        class="min-h-screen w-full bg-bone px-6 md:px-16 lg:px-20 pt-36 md:pt-52 pb-32 text-darkRed"
    >
        <section class="w-full mx-auto mb-16">
            <div
                class="flex flex-col md:flex-row justify-between items-center gap-8 pb-8 relative"
            >
                <div class="flex justify-between items-center w-full">
                    <CrystalButtonInterior
                        text="Back"
                        onClick="history.back()"
                    />

                    <h1
                        class="text-3xl md:hidden font-serif tracking-[0.2em] uppercase text-center"
                    >
                        {title}
                    </h1>
                </div>
                <h1
                    class="hidden md:block absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 text-4xl md:text-6xl lg:text-7xl font-serif tracking-[0.2em] uppercase text-center"
                >
                    {title}
                </h1>
                <div class="relative w-full md:w-88 lg:w-96 self-end">
                    <input
                        id="search-input"
                        type="text"
                        placeholder=""
                        autocomplete="off"
                        class="w-full bg-transparent border-b-[0.5px] md:border-b border-darkRed/40 md:border-darkRed/80 focus:outline-none pb-1 pr-10 text-lg md:text-4xl lg:text-3xl"
                    />

                    <Find
                        class="h-6 w-6 md:h-10 md:w-10 absolute right-0 bottom-2"
                    />
                </div>
            </div>
        </section>

        <section class="w-full mx-auto">
            <p
                id="no-results"
                class="hidden text-center text-darkRed/60 text-xl py-20"
            >
                No se encontraron productos.
            </p>
            <div
                id="products-grid"
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16"
            >
                {
                    products.map(({ node }: any) => (
                        <div
                            class="product-card relative group flex flex-col aspect-square items-center justify-center p-8 transition-all bg-transparent hover:bg-stone-50/50 cursor-pointer"
                            data-title={node.title.toLowerCase()}
                        >
                            <a href={`/products/${node.handle}`} class="absolute inset-0 z-10" aria-label={`View details for ${node.title}`}></a>
                            
                            <div class="relative flex flex-col items-center justify-center ">
                                <Plus class="z-20 absolute top-2 left-2   pointer-events-none" />
                                <Plus class="z-20 absolute top-2 right-2    pointer-events-none" />
                                <Plus class="z-20 absolute bottom-2 left-2   pointer-events-none" />
                                <Plus class="z-20 absolute bottom-2 right-2  pointer-events-none" />

                                <div class="w-full aspect-5/4 mb-6 flex items-center justify-center relative">
                                    {node.hoverImage?.reference?.image?.url && (
                                        <img
                                            src={
                                                node.hoverImage.reference.image
                                                    .url
                                            }
                                            alt={
                                                node.hoverImage.reference.image
                                                    .altText || node.title
                                            }
                                            class="hidden md:block absolute inset-0 w-full h-full max-h-full max-w-full object-contain object-center aspect-5/4 drop-shadow-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-in-out z-10 pointer-events-none"
                                        />
                                    )}
                                    <img
                                        src={node.images.edges[0]?.node.url}
                                        alt={
                                            node.images.edges[0]?.node
                                                .altText || node.title
                                        }
                                        class="max-h-full max-w-full object-contain object-center aspect-5/4 drop-shadow-2xl md:group-hover:opacity-0 transition-opacity duration-500 ease-in-out pointer-events-none"
                                    />
                                </div>

                                <div class="text-center space-y-2 pointer-events-none">
                                    <h3 class="text-lg md:text-xl lg:text-3xl px-4 leading-relaxed text-darkRed/80">
                                        {node.title}
                                    </h3>
                                    <h4 class="block mt-1 text-xl md:text-xl lg:text-4xl">
                                        $
                                        {Math.round(
                                            node.priceRange.minVariantPrice
                                                .amount,
                                        )}{" "}
                                        {
                                            node.priceRange.minVariantPrice
                                                .currencyCode
                                        }
                                    </h4>
                                </div>
                            </div>
                            <div class="relative z-20 flex flex-col items-center gap-3 mt-8">
                                <CrystalButton
                                    text="Show Details"
                                    href={`/products/${node.handle}`}
                                    className="text-darkRed bg-linear-to-br! from-darkRed/25! via-darkRed/12! to-darkRed/8!"
                                />
                                {node.variants?.edges?.[0]?.node?.id && (
                                    <button
                                        class="add-to-cart-btn relative shadow-md text-[clamp(0.45rem,0.45rem+0.8vw,0.8rem)] md:text-xl lg:text-2xl lg:py-5 lg:px-10 py-3 px-4 md:py-4 md:px-8 inline-flex items-center justify-center rounded-full border border-[#68150A]/20 bg-gradient-to-br from-[#68150A]/20 via-[#68150A]/10 to-[#68150A]/5 backdrop-blur-sm text-darkRed transition-transform duration-300 hover:scale-[1.05] active:scale-95 cursor-pointer disabled:opacity-50"
                                        data-variant-id={node.variants.edges[0].node.id}
                                        data-product-title={node.title}
                                        data-price-amount={node.priceRange.minVariantPrice.amount}
                                        data-price-currency={node.priceRange.minVariantPrice.currencyCode}
                                        data-image-url={node.images.edges[0]?.node.url ?? ""}
                                        data-image-alt={node.images.edges[0]?.node.altText ?? ""}
                                        data-quantity-available={node.variants.edges[0].node.quantityAvailable ?? ""}
                                    >
                                        <span class="btn-label relative z-10 uppercase tracking-wider whitespace-nowrap select-none">
                                            Add to Cart
                                        </span>
                                    </button>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

        <div class="h-20"></div>
    </main>
</Layout>

<script>
    function initSearch() {
        const input = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        const cards = document.querySelectorAll<HTMLElement>(".product-card");
        const noResults = document.getElementById("no-results");

        if (!input) return;

        input.addEventListener("input", () => {
            const term = input.value.trim().toLowerCase();
            let visible = 0;

            cards.forEach((card) => {
                const title = card.dataset.title || "";
                const match = title.includes(term);
                card.style.display = match ? "" : "none";
                if (match) visible++;
            });

            if (noResults) {
                noResults.classList.toggle("hidden", visible > 0);
            }
        });
    }

    initSearch();
    document.addEventListener("astro:page-load", initSearch);

    // ── Add to Cart buttons ───────────────────────────────────────────────────

    function initAddToCartButtons() {
        const buttons = document.querySelectorAll<HTMLButtonElement>(".add-to-cart-btn");

        buttons.forEach((btn) => {
            // Remove any previously attached listeners (page re-renders)
            const newBtn = btn.cloneNode(true) as HTMLButtonElement;
            btn.parentNode?.replaceChild(newBtn, btn);

            newBtn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation(); // don't navigate to product page

                const variantId = newBtn.dataset.variantId;
                const title = newBtn.dataset.productTitle;
                if (!variantId) return;

                const priceAmount = newBtn.dataset.priceAmount ?? "";
                const priceCurrency = newBtn.dataset.priceCurrency ?? "USD";
                const imageUrl = newBtn.dataset.imageUrl ?? "";
                const imageAlt = newBtn.dataset.imageAlt ?? "";
                const qtyAvailable = newBtn.dataset.quantityAvailable
                    ? parseInt(newBtn.dataset.quantityAvailable, 10)
                    : null;

                newBtn.disabled = true;
                const label = newBtn.querySelector(".btn-label");
                if (label) label.textContent = "Adding…";

                window.dispatchEvent(
                    new CustomEvent("addToCart", {
                        detail: {
                            variantId,
                            title,
                            price: priceAmount
                                ? { amount: priceAmount, currencyCode: priceCurrency }
                                : null,
                            image: imageUrl
                                ? { url: imageUrl, altText: imageAlt }
                                : null,
                            quantityAvailable: qtyAvailable,
                        },
                    })
                );

                setTimeout(() => {
                    newBtn.disabled = false;
                    if (label) label.textContent = "Add to Cart";
                }, 1800);
            });
        });
    }

    initAddToCartButtons();
    document.addEventListener("astro:page-load", initAddToCartButtons);
</script>

<style>
    /* Ajuste para que los bordes del grid no se dupliquen visualmente de forma tosca */
    .grid {
        border-collapse: collapse;
    }
    span {
        font-family: "Montage" !important;
    }
</style>
