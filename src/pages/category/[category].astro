---
import CrystalButtonInterior from "../../components/helpers/CrystalButtonInterior.astro";
import Layout from "../../layouts/Layout.astro";
import Find from "../../assets/find.svg";
import CrystalButton from "../../components/helpers/CrystalButton.astro";
import Plus from "../../assets/plus-sign.svg";
import { Image } from "astro:assets";

// Limita el ancho de la imagen en el CDN de Shopify antes de que Astro la descargue,
// reduciendo el peso de red en el build y en el cliente.
const shopifyImg = (url: string, maxWidth: number) => {
    if (!url) return url;
    try {
        const u = new URL(url);
        u.searchParams.set("width", String(maxWidth));
        return u.toString();
    } catch {
        return url;
    }
};

// 1. Configuración de parámetros y rutas
export async function getStaticPaths() {
    return [
        {
            params: { category: "rings" },
            props: { title: "RINGS", handle: "rings", seoTitle: "Gold Rings — Handcrafted 14k & 18k Jewelry" },
        },
        {
            params: { category: "necklaces" },
            props: { title: "NECKLACES", handle: "necklaces", seoTitle: "Gold Necklaces — Handcrafted 14k & 18k Jewelry" },
        },
    ];
}

const { category } = Astro.params;
const { title, handle, seoTitle } = Astro.props;

// 2. Llamada a la Storefront API de Shopify
// Nota: Reemplaza con tus variables de entorno reales
const SHOPIFY_DOMAIN = import.meta.env.SHOPIFY_DOMAIN;
const STOREFRONT_ACCESS_TOKEN = import.meta.env.STOREFRONT_ACCESS_TOKEN;

const query = `
  query getProductsByCollection($handle: String!) {
    collection(handle: $handle) {
      products(first: 12) {
        edges {
          node {
            id
            title
            handle
            priceRange {
              minVariantPrice {
                amount
                currencyCode
              }
            }
            images(first: 1) {
              edges {
                node {
                  url
                  altText
                }
              }
            }
            variants(first: 1) {
              edges {
                node {
                  id
                  quantityAvailable
                }
              }
            }
            hoverImage: metafield(namespace: "custom", key: "hover_image") {
              reference {
                ... on MediaImage {
                  image {
                    url
                    altText
                  }
                }
              }
            }
          }
        }
      }
    }
  }
`;
console.log("DEBUG - Parámetro categoría:", category);
console.log("DEBUG - Variable handle que enviaré:", handle);
const handleToSend = String(handle).trim();

const response = await fetch(
    `https://${SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
    {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "X-Shopify-Storefront-Access-Token": STOREFRONT_ACCESS_TOKEN,
        },
        body: JSON.stringify({
            query,
            variables: {
                handle: handleToSend,
            },
        }),
    },
);

const json = await response.json();

if (json.errors) {
    console.error(
        "Error detallado de Shopify:",
        JSON.stringify(json.errors, null, 2),
    );
}

const products = json.data?.collection?.products?.edges || [];

// SEO
const categoryDescriptions: Record<string, string> = {
    rings: "Browse our collection of fine gold rings — handcrafted in 14k and 18k gold. Elegant designs for every occasion. Shop Coronado Gold rings today.",
    necklaces: "Discover our exquisite gold necklace collection — handcrafted in 14k and 18k gold. Timeless elegance from Coronado Gold. Free shipping available.",
};
const metaDescription = categoryDescriptions[category as string] ?? `Shop fine gold ${title.toLowerCase()} from Coronado Gold — handcrafted jewelry delivered worldwide.`;

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://goldcoronado.com/" },
        { "@type": "ListItem", "position": 2, "name": title, "item": `https://goldcoronado.com/category/${category}/` }
    ]
};

const itemListSchema = {
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `${title} — Coronado Gold`,
    "url": `https://goldcoronado.com/category/${category}/`,
    "itemListElement": (products as any[]).map(({ node }: any, i: number) => ({
        "@type": "ListItem",
        "position": i + 1,
        "url": `https://goldcoronado.com/products/${node.handle}/`
    }))
};
---

<Layout title={seoTitle} description={metaDescription}>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
    </Fragment>
    <main
        class="min-h-screen w-full bg-bone px-6 md:px-16 lg:px-20 pt-36 md:pt-52 pb-32 text-darkRed"
    >
        <section class="w-full mx-auto mb-16">
            <div
                class="flex flex-col md:flex-row justify-between items-center gap-8 pb-8 relative"
            >
                <div class="flex justify-between items-center w-full">
                    <CrystalButtonInterior
                        text="Back"
                        onClick="__cgBack()"
                        className="px-6 py-2.5 rounded-full bg-gray-400/15 border border-darkRed/20 text-darkRed tracking-widest text-sm "
                    />

                    <p
                        aria-hidden="true"
                        class="text-3xl md:hidden font-serif tracking-[0.2em] uppercase text-center"
                    >
                        {title}
                    </p>
                </div>
                <h1
                    class="hidden md:block absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 text-4xl md:text-6xl lg:text-7xl font-serif tracking-[0.2em] uppercase text-center"
                >
                    {title}
                </h1>
                <div
                    class="relative w-full md-custom:w-1/2 md:w-110 lg:w-160 self-end"
                >
                    <input
                        id="search-input"
                        type="text"
                        placeholder=""
                        autocomplete="off"
                        class="w-full bg-transparent border-b-[0.5px] md:border-b border-darkRed/40 md:border-darkRed/50 focus:outline-none pb-1 pr-8 md:pr-16 lg:pr-14 text-lg md:text-4xl lg:text-3xl"
                    />

                    <Find
                        class="h-6 w-6 md:h-14 md:w-14 lg:w-12 lg:h-12 absolute right-0 bottom-2"
                    />
                </div>
            </div>
        </section>

        <section class="w-full mx-auto flex justify-center">
            <p
                id="no-results"
                class="hidden md-custom:text-lg md:text-4xl text-center text-darkRed/60 text-xl py-20"
            >
                No products found.
            </p>
            <div
                id="products-grid"
                class="grid grid-cols-1 md-custom:w-4/5 md:w-full md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-16 md:gap-22 lg:gap-16"
            >
                {
                    products.map(({ node }: any) => (
                        <div
                            class="product-card relative group flex flex-col aspect-square items-center justify-center p-8 transition-all bg-transparent hover:bg-stone-50/50 cursor-pointer"
                            data-title={node.title.toLowerCase()}
                        >
                            <a
                                href={`/products/${node.handle}`}
                                class="absolute inset-0 z-10"
                                aria-label={`View details for ${node.title}`}
                            />

                            <div class="relative flex flex-col items-center justify-center ">
                                <Plus class="md:h-6 lg:h-4 h-3 aspect-square z-20 absolute top-2 left-2   pointer-events-none" />
                                <Plus class="md:h-6 lg:h-4 h-3 aspect-square z-20 absolute top-2 right-2    pointer-events-none" />
                                <Plus class="md:h-6 lg:h-4 h-3 aspect-square z-20 absolute bottom-2 left-2   pointer-events-none" />
                                <Plus class="md:h-6 lg:h-4 h-3 aspect-square z-20 absolute bottom-2 right-2  pointer-events-none" />

                                <div class="cat-img-wrapper w-full aspect-5/4 mb-6 flex items-center justify-center relative">
                                    {node.hoverImage?.reference?.image?.url && (
                                        <Image
                                            src={shopifyImg(node.hoverImage.reference.image.url, 960)}
                                            alt={node.hoverImage.reference.image.altText || node.title}
                                            width={960}
                                            inferSize
                                            class="hidden md:block absolute inset-0 w-full h-full max-h-full max-w-full object-contain object-center aspect-5/4 drop-shadow-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-in-out z-10 pointer-events-none"
                                        />
                                    )}
                                    <Image
                                        src={shopifyImg(node.images.edges[0]?.node.url, 960)}
                                        alt={node.images.edges[0]?.node.altText || node.title}
                                        width={960}
                                        inferSize
                                        class="cat-main-img max-h-full max-w-full object-contain object-center aspect-5/4 drop-shadow-2xl md:group-hover:opacity-0 transition-opacity duration-500 ease-in-out pointer-events-none"
                                    />
                                    <!-- Skeleton encima: se desvanece cuando la imagen carga -->
                                    <div class="cat-img-skeleton skeleton absolute inset-0 rounded-xl transition-opacity duration-500 z-20 pointer-events-none" />
                                </div>

                                <div class="text-center space-y-2 pointer-events-none">
                                    <h3 class="text-lg md:text-4xl lg:text-3xl px-4 leading-relaxed text-darkRed/80">
                                        {node.title}
                                    </h3>
                                    <h4 class="block mt-1 text-xl md:text-5xl lg:text-4xl">
                                        $
                                        {Math.round(
                                            node.priceRange.minVariantPrice
                                                .amount,
                                        )}{" "}
                                        {
                                            node.priceRange.minVariantPrice
                                                .currencyCode
                                        }
                                    </h4>
                                </div>
                            </div>
                            <div class="relative z-20 flex  items-center gap-3 md:gap-12 lg:gap-4 mt-8">
                                <CrystalButton
                                    text="Show Details"
                                    href={`/products/${node.handle}`}
                                    className="md:text-[clamp(2rem,1rem+1vw,3rem)] text-darkRed"
                                />
                                {node.variants?.edges?.[0]?.node?.id && (
<button
    class="add-to-cart-btn h-full aspect-square relative inline-flex items-center justify-center rounded-full transition-all duration-300 hover:scale-[1.05] active:scale-95 cursor-pointer disabled:opacity-50 lg:py-5 lg:px-10 py-3 px-4 md:py-4 md:px-8 text-darkRed! bg-linear-to-br! from-darkRed/25! via-darkRed/12! to-darkRed/8! "
    data-variant-id={node.variants.edges[0].node.id}
    data-product-title={node.title}
    data-price-amount={node.priceRange.minVariantPrice.amount}
    data-price-currency={node.priceRange.minVariantPrice.currencyCode}
    data-image-url={node.images.edges[0]?.node.url ?? ""}
    data-image-alt={node.images.edges[0]?.node.altText ?? ""}
    data-quantity-available={node.variants.edges[0].node.quantityAvailable ?? ""}
    style={{
        /* Gradiente para volumen 3D */
        background: "linear-gradient(145deg, #e6e1de 0%, #dbd4d0 100%)",

        /* Borde de luz sutil */
        border: "1px solid rgba(255, 255, 255, 0.4)",

        /* 1. Elevación (Sombra caída)
           2. Sombra de contacto
           3. Brillo interno superior (Efecto cristal)
           4. Profundidad interna inferior
        */
        boxShadow: [
            "0 15px 25px -5px rgba(0, 0, 0, 0.15)",
            "0 8px 10px -6px rgba(0, 0, 0, 0.1)",
            "inset 2px 2px 4px rgba(255, 255, 255, 0.7)",
            "inset -2px -2px 5px rgba(0, 0, 0, 0.05)",
        ].join(", "),
    }}
>
    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.04] mix-blend-overlay rounded-full [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span 
        class="btn-label relative z-10 text-darkRed"
        style={{ filter: "drop-shadow(0.5px 0.5px 0px rgba(255,255,255,0.4))" }}
    >
        <Plus class="md:h-8 lg:h-6 h-4" />
    </span>
</button>
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

        <div class="h-20"></div>
    </main>
</Layout>

<script>
    function initSearch() {
        const input = document.getElementById(
            "search-input",
        ) as HTMLInputElement;
        const cards = document.querySelectorAll<HTMLElement>(".product-card");
        const noResults = document.getElementById("no-results");

        if (!input) return;

        input.addEventListener("input", () => {
            const term = input.value.trim().toLowerCase();
            let visible = 0;

            cards.forEach((card) => {
                const title = card.dataset.title || "";
                const match = title.includes(term);
                card.style.display = match ? "" : "none";
                if (match) visible++;
            });

            if (noResults) {
                noResults.classList.toggle("hidden", visible > 0);
            }
        });
    }

    initSearch();
    document.addEventListener("astro:page-load", initSearch);

    // ── Add to Cart buttons ───────────────────────────────────────────────────

    function initAddToCartButtons() {
        const buttons =
            document.querySelectorAll<HTMLButtonElement>(".add-to-cart-btn");

        buttons.forEach((btn) => {
            // Remove any previously attached listeners (page re-renders)
            const newBtn = btn.cloneNode(true) as HTMLButtonElement;
            btn.parentNode?.replaceChild(newBtn, btn);

            newBtn.addEventListener("click", (e) => {
                e.preventDefault();
                e.stopPropagation(); // don't navigate to product page

                const variantId = newBtn.dataset.variantId;
                const title = newBtn.dataset.productTitle;
                if (!variantId) return;

                const priceAmount = newBtn.dataset.priceAmount ?? "";
                const priceCurrency = newBtn.dataset.priceCurrency ?? "USD";
                const imageUrl = newBtn.dataset.imageUrl ?? "";
                const imageAlt = newBtn.dataset.imageAlt ?? "";
                const qtyAvailable = newBtn.dataset.quantityAvailable
                    ? parseInt(newBtn.dataset.quantityAvailable, 10)
                    : null;

                newBtn.disabled = true;

                window.dispatchEvent(
                    new CustomEvent("addToCart", {
                        detail: {
                            variantId,
                            title,
                            price: priceAmount
                                ? {
                                      amount: priceAmount,
                                      currencyCode: priceCurrency,
                                  }
                                : null,
                            image: imageUrl
                                ? { url: imageUrl, altText: imageAlt }
                                : null,
                            quantityAvailable: qtyAvailable,
                        },
                    }),
                );

                setTimeout(() => {
                    newBtn.disabled = false;
                }, 1800);
            });
        });
    }

    initAddToCartButtons();
    document.addEventListener("astro:page-load", initAddToCartButtons);

    // ── Skeletons de imágenes ─────────────────────────────────────────────────
    function initCategorySkeletons() {
        document.querySelectorAll<HTMLElement>(".cat-img-wrapper").forEach((wrapper) => {
            const img = wrapper.querySelector<HTMLImageElement>(".cat-main-img");
            const skeleton = wrapper.querySelector<HTMLElement>(".cat-img-skeleton");
            if (!img || !skeleton) return;

            function reveal() {
                skeleton!.classList.add("opacity-0");
            }

            // Si ya estaba en caché, desvanece de inmediato
            if (img.complete && img.naturalWidth > 0) {
                reveal();
            } else {
                img.addEventListener("load", reveal, { once: true });
            }
        });
    }

    initCategorySkeletons();
    document.addEventListener("astro:page-load", initCategorySkeletons);
</script>

<style>
    /* Ajuste para que los bordes del grid no se dupliquen visualmente de forma tosca */
    .grid {
        border-collapse: collapse;
    }
    span {
        font-family: "Montage" !important;
    }
</style>
