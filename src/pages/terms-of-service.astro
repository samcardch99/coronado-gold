---
import Layout from "../layouts/Layout.astro";

const response = await fetch(
    `https://${import.meta.env.SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
    {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "X-Shopify-Storefront-Access-Token":
                import.meta.env.STOREFRONT_ACCESS_TOKEN,
        },
        body: JSON.stringify({
            query: `{
                shop {
                    termsOfService {
                        title
                        body
                    }
                }
            }`,
        }),
    }
);

const json = await response.json();
const policy = json.data?.shop?.termsOfService;
---

<Layout title="Terms & Conditions">
    <main class="bg-bone text-darkRed min-h-screen">
        <section class="w-full px-6 md:px-16 lg:px-20 pt-44 md:pt-52 lg:pt-56 pb-24 md:pb-32">
            <div class="max-w-3xl lg:max-w-5xl mx-auto">

                {policy ? (
                    <>
                        <h1 class="font-serif text-3xl md:text-6xl lg:text-8xl tracking-wider leading-tight mb-10 md:mb-16">
                            {policy.title}
                        </h1>
                        <hr class="border-darkRed/25 mb-10 md:mb-14" />
                        <div
                            class="policy-body text-sm md:text-xl lg:text-2xl leading-relaxed tracking-wide text-darkRed/80 space-y-6"
                            set:html={policy.body}
                        />
                    </>
                ) : (
                    <p class="text-sm md:text-xl lg:text-2xl text-darkRed/60 tracking-wide">
                        Terms & Conditions not available at this time.
                    </p>
                )}

            </div>
        </section>
    </main>
</Layout>

<style>
    .policy-body :global(h1),
    .policy-body :global(h2),
    .policy-body :global(h3) {
        font-family: var(--font-serif, serif);
        font-size: 1.25em;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: var(--color-darkRed, #68150a);
        letter-spacing: 0.05em;
    }

    .policy-body :global(p) {
        margin-bottom: 1rem;
    }

    .policy-body :global(a) {
        text-decoration: underline;
        text-underline-offset: 4px;
        opacity: 0.75;
        transition: opacity 0.2s;
    }

    .policy-body :global(a:hover) {
        opacity: 1;
    }

    .policy-body :global(ul),
    .policy-body :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .policy-body :global(li) {
        margin-bottom: 0.5rem;
    }
</style>
