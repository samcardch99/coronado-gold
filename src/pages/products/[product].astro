---
import Layout from "../../layouts/Layout.astro";
import CrystalButton from "../../components/helpers/CrystalButton.astro";
import CrystalButtonInterior from "../../components/helpers/CrystalButtonInterior.astro";
import Plus from "../../assets/plus-sign.svg";
import { Image } from "astro:assets";

// Reduce el ancho de la imagen en el CDN de Shopify antes de que Astro la descargue.
const shopifyImg = (url: string, maxWidth: number) => {
    if (!url) return url;
    try {
        const u = new URL(url);
        u.searchParams.set("width", String(maxWidth));
        return u.toString();
    } catch {
        return url;
    }
};

export async function getStaticPaths() {
    const response = await fetch(
        `https://${import.meta.env.SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
        {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Shopify-Storefront-Access-Token":
                    import.meta.env.STOREFRONT_ACCESS_TOKEN,
            },
            body: JSON.stringify({
                query: `{
          products(first: 100) {
            edges {
              node {
                handle
                title
                description
                priceRange {
                  minVariantPrice { amount currencyCode }
                }
                images(first: 1) {
                  edges { node { url altText } }
                }
                variants(first: 1) {
                  edges { node { id quantityAvailable } }
                }
                hoverImage: metafield(namespace: "custom", key: "hover_image") {
                  reference {
                    ... on MediaImage {
                      image { url altText }
                    }
                  }
                }
                kilates: metafield(namespace: "custom", key: "quilates") {
                  value
                }
              }
            }
          }
        }`,
            }),
        },
    );

    const json = await response.json();
    const products = json.data?.products?.edges || [];

    return products.map(({ node }: any) => ({
        params: { product: node.handle },
        props: { product: node },
    }));
}

const { product } = Astro.props;

const mainImage = product.images.edges[0]?.node;
const hoverImage = product.hoverImage?.reference?.image;

const price = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: product.priceRange.minVariantPrice.currencyCode,
}).format(parseFloat(product.priceRange.minVariantPrice.amount));

const kilates = product.kilates?.value ?? null;
const variantId = product.variants?.edges?.[0]?.node?.id ?? null;
const quantityAvailable = product.variants?.edges?.[0]?.node?.quantityAvailable ?? null;

// Citas hardcodeadas por categoría
const CATEGORY_QUOTES = {
    rings: {
        text: "Wear a fabulous smile, great jewelry and know that you are totally and absolutely in control.",
        author: "Donatella Versace",
    },
    necklaces: {
        text: "To me, the power of a piece of jewelry is its beauty, its allure, the memory it evokes, and the way it makes me feel when I wear it.",
        author: "Carolina Herrera",
    },
    earrings: {
        text: "My jewelry represents an idea above all! I wanted to cover women with constellations.",
        author: "Coco Chanel",
    },
};

// Detecta categoría por palabras clave en el handle del producto
const handle = (product.handle as string).toLowerCase();

const categoryQuote =
    handle.includes("ring") || handle.includes("anillo")
        ? CATEGORY_QUOTES.rings
        : handle.includes("necklace") || handle.includes("collar") || handle.includes("chain") || handle.includes("cadena")
          ? CATEGORY_QUOTES.necklaces
          : handle.includes("earring") || handle.includes("pendant") || handle.includes("arete") || handle.includes("pendiente") || handle.includes("stud")
            ? CATEGORY_QUOTES.earrings
            : CATEGORY_QUOTES.rings; // fallback: siempre muestra una cita
---

<Layout title={product.title}>
    <main class="bg-bone text-darkRed">

        <!-- ── SECTION 1: Product details ── -->
        <section class="min-h-screen w-full px-6 md:px-16 lg:px-20 pt-44 md:pt-48 lg:pt-56 pb-20 flex flex-col justify-center items-center">
<div class="flex flex-col w-full md-custom:flex-row md-custom:justify-between lg:justify-center md-custom:items-start md-custom:gap-16 lg:gap-80">
            <!-- IMAGE COLUMN -->
            <div class="w-full md:w-1/2 md:max-w-2xl lg:max-w-3xl flex flex-col items-center">
                <!-- Image with corner decorations -->
                <div class="relative aspect-square w-full h-full max-w-sm md:max-w-xl lg:max-w-max flex items-center justify-center p-8">
                    <Plus class="md:h-8 lg:h-6 h-4 absolute top-2 left-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute top-2 right-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute bottom-2 left-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute bottom-2 right-2 z-20 pointer-events-none" />

                    {mainImage?.url && (
                        <Image
                            src={shopifyImg(mainImage.url, 1280)}
                            alt={mainImage.altText || product.title}
                            width={1280}
                            inferSize
                            class="w-full h-full object-contain drop-shadow-2xl"
                        />
                    )}
                </div>

                <!-- Price + CTA (mobile: below image, desktop: below image column) -->
                <p class="text-2xl md-custom:text-[clamp(2rem, 1rem+0.1vw, 3rem)] md:text-4xl lg:text-4xl tracking-widest mt-4 md:mt-6">
                    {price}
                </p>

                <div class="mt-6 md:mt-8">
                    <!-- Always active — variantId fetched at runtime if not in static props -->
                    <button
                        id="add-to-cart-btn"
                        data-variant-id={variantId ?? ""}
                        data-product-handle={product.handle}
                        data-product-title={product.title}
                        data-price-amount={product.priceRange.minVariantPrice.amount}
                        data-price-currency={product.priceRange.minVariantPrice.currencyCode}
                        data-image-url={mainImage?.url ?? ""}
                        data-image-alt={mainImage?.altText ?? ""}
                        data-quantity-available={quantityAvailable ?? ""}
                        class="relative shadow-lg text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-3xl lg:text-3xl lg:py-7 lg:px-12 py-4 px-4 md:py-6 md:px-10 inline-flex items-center justify-center rounded-full border border-white/30 bg-gradient-to-br from-[#68150A]/25 via-[#68150A]/12 to-[#68150A]/8 backdrop-blur-sm text-darkRed transition-transform duration-300 hover:scale-[1.05] active:scale-95 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
                    >
                        <span class="btn-label relative z-10 uppercase tracking-wider whitespace-nowrap select-none">
                            Add to Cart
                        </span>
                    </button>
                </div>
            </div>

            <!-- INFO COLUMN -->
            <div class="w-full md:w-1/2 mt-12 md-custom:mt-0 flex flex-col justify-center">

               
                <!-- Title -->
                <h1 class="font-serif text-3xl md-custom:text-[clamp(2rem, 1rem+0.1vw, 3rem)] md:text-6xl  lg:text-8xl tracking-wider  leading-tight">
                    {product.title}
                </h1>

                <!-- Divider -->
                <hr class="border-darkRed/25 mt-4 mb-6 " />

                <!-- Description -->
                {product.description && (
                    <p class=" text-sm md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-2xl lg:text-3xl leading-relaxed tracking-wide  text-darkRed/80 max-w-xl lg:max-w-5xl">
                        {product.description}
                    </p>
                )}

                <!-- Specs table -->
                {kilates && (
                    <div class="mt-6">
                        <hr class="border-darkRed/25 mb-4" />
                        <!-- Header -->
                        <div class="grid grid-cols-2 gap-x-8">
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.2em]  text-darkRed/50 pb-3">Feature</p>
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.2em]  text-darkRed/50 pb-3">Specification</p>
                        </div>
                        <hr class="border-darkRed/25" />
                        <!-- Row: Kilates -->
                        <div class="grid grid-cols-2 gap-x-8 py-3">
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.15em] ">Kilates</p>
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.15em] ">{kilates}</p>
                        </div>
                    </div>
                )}
            </div>
        </div>
        </section>

        <div class="fixed top-28 left-6 md:top-52 md:left-20 z-30">
            <CrystalButtonInterior  
                text="Back"
                onClick="history.back()"
                className="px-6 py-2.5 rounded-full bg-gray-400/15 border border-darkRed/20 text-darkRed tracking-widest text-sm "
            />
        </div>

        <!-- ── SECTION 2: Full-bleed hover image with quote ── -->
        {hoverImage?.url && (
            <section class="relative w-full bg-[#D4CBC8] h-screen flex items-end md:items-center justify-end overflow-hidden">
                <!-- Background image -->
                <Image
                    src={shopifyImg(hoverImage.url, 1920)}
                    alt={hoverImage.altText || product.title}
                    width={1920}
                    inferSize
                    class=" absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full aspect-square object-contain object-center"
                />

                <!-- Quote overlay -->
                {categoryQuote && (
                    <div class="relative z-10 w-full flex justify-end items-end md:items-center px-8 pb-16 md:pb-28 lg:pb-32 md:px-20">
                        <div class="text-right max-w-xs md-custom:max-w-sm md:max-w-110 lg:max-w-2xl xl:max-w-3xl">
                            <p class="font-serif text-sm  md:text-3xl lg:text-4xl leading-relaxed tracking-wide text-darkRed  italic">
                                "{categoryQuote.text}"
                            </p>
                            <p class="font-serif text-xs  md:text-3xl lg:text-4xl tracking-widest text-darkRed/70 mt-3 ">
                                — {categoryQuote.author}
                            </p>
                        </div>
                    </div>
                )}
            </section>
        )}

    </main>
</Layout>

<script>
    // Fetches the first variant ID for a product handle via Storefront API
    async function fetchVariantId(handle: string): Promise<string | null> {
        const cfg = (window as any).__SHOPIFY_CONFIG__;
        if (!cfg) return null;
        try {
            const res = await fetch(
                `https://${cfg.domain}/api/2024-01/graphql.json`,
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Shopify-Storefront-Access-Token": cfg.token,
                    },
                    body: JSON.stringify({
                        query: `query getVariant($handle: String!) {
                            productByHandle(handle: $handle) {
                                variants(first: 1) { edges { node { id } } }
                            }
                        }`,
                        variables: { handle },
                    }),
                }
            );
            const json = await res.json();
            return (
                json.data?.productByHandle?.variants?.edges?.[0]?.node?.id ?? null
            );
        } catch {
            return null;
        }
    }

    function initAddToCart() {
        const btn = document.getElementById(
            "add-to-cart-btn"
        ) as HTMLButtonElement | null;
        if (!btn) return;

        // Clone to remove any previously bound listeners (view transitions)
        const fresh = btn.cloneNode(true) as HTMLButtonElement;
        btn.parentNode?.replaceChild(fresh, btn);

        fresh.addEventListener("click", async () => {
            const title = fresh.dataset.productTitle ?? "";
            const handle = fresh.dataset.productHandle ?? "";
            let variantId = fresh.dataset.variantId ?? "";

            // Build product data for the optimistic cart update
            const priceAmount = fresh.dataset.priceAmount ?? "";
            const priceCurrency = fresh.dataset.priceCurrency ?? "USD";
            const imageUrl = fresh.dataset.imageUrl ?? "";
            const imageAlt = fresh.dataset.imageAlt ?? "";
            const qtyAvailable = fresh.dataset.quantityAvailable
                ? parseInt(fresh.dataset.quantityAvailable, 10)
                : null;

            fresh.disabled = true;
            const label = fresh.querySelector(".btn-label");
            if (label) label.textContent = "Adding…";

            // Fallback: fetch variant ID from Shopify if not in static data
            if (!variantId && handle) {
                variantId = (await fetchVariantId(handle)) ?? "";
                if (variantId) {
                    fresh.dataset.variantId = variantId;
                }
            }

            if (!variantId) {
                if (label) label.textContent = "Not available";
                setTimeout(() => {
                    fresh.disabled = false;
                    if (label) label.textContent = "Add to Cart";
                }, 2000);
                return;
            }

            window.dispatchEvent(
                new CustomEvent("addToCart", {
                    detail: {
                        variantId,
                        title,
                        price: priceAmount
                            ? { amount: priceAmount, currencyCode: priceCurrency }
                            : null,
                        image: imageUrl
                            ? { url: imageUrl, altText: imageAlt }
                            : null,
                        quantityAvailable: qtyAvailable,
                    },
                })
            );

            setTimeout(() => {
                fresh.disabled = false;
                if (label) label.textContent = "Add to Cart";
            }, 1800);
        });
    }

    initAddToCart();
    document.addEventListener("astro:page-load", initAddToCart);
</script>
