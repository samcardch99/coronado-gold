---
import Layout from "../../layouts/Layout.astro";
import CrystalButton from "../../components/helpers/CrystalButton.astro";
import CrystalButtonInterior from "../../components/helpers/CrystalButtonInterior.astro";
import Plus from "../../assets/plus-sign.svg";
import { Image } from "astro:assets";

// Reduce el ancho de la imagen en el CDN de Shopify antes de que Astro la descargue.
const shopifyImg = (url: string, maxWidth: number) => {
    if (!url) return url;
    try {
        const u = new URL(url);
        u.searchParams.set("width", String(maxWidth));
        return u.toString();
    } catch {
        return url;
    }
};

export async function getStaticPaths() {
    const response = await fetch(
        `https://${import.meta.env.SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
        {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Shopify-Storefront-Access-Token":
                    import.meta.env.STOREFRONT_ACCESS_TOKEN,
            },
            body: JSON.stringify({
                query: `{
          products(first: 100) {
            edges {
              node {
                handle
                title
                description
                priceRange {
                  minVariantPrice { amount currencyCode }
                }
                images(first: 1) {
                  edges { node { url altText } }
                }
                options { name }
                variants(first: 100) {
                  edges {
                    node {
                      id
                      title
                      availableForSale
                      quantityAvailable
                      price { amount currencyCode }
                    }
                  }
                }
                interiorImage: metafield(namespace: "custom", key: "interior_image") {
                  reference {
                    ... on MediaImage {
                      image { url altText }
                    }
                  }
                }
                interiorImageMobile: metafield(namespace: "custom", key: "interior_image_mobile") {
                  reference {
                    ... on MediaImage {
                      image { url altText }
                    }
                  }
                }
                kilates: metafield(namespace: "custom", key: "quilates") {
                  value
                }
              }
            }
          }
        }`,
            }),
        },
    );

    const json = await response.json();
    const products = json.data?.products?.edges || [];

    return products.map(({ node }: any) => ({
        params: { product: node.handle },
        props: { product: node },
    }));
}

const { product } = Astro.props;

const mainImage = product.images.edges[0]?.node;
const interiorImage = product.interiorImage?.reference?.image;
const interiorImageMobile = product.interiorImageMobile?.reference?.image;

const price = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: product.priceRange.minVariantPrice.currencyCode,
}).format(parseFloat(product.priceRange.minVariantPrice.amount));

const kilates = product.kilates?.value ?? null;

// Variants / sizes
const rawVariants = (product.variants?.edges ?? []).map((e: any) => e.node);
const optionName = product.options?.[0]?.name ?? null;
const hasRealSizes = rawVariants.length > 0 &&
    !(rawVariants.length === 1 && rawVariants[0].title === "Default Title");
const sizeVariants = hasRealSizes ? rawVariants : [];
// For products without sizes, the single default variant is used directly
const variantId = !hasRealSizes ? (rawVariants[0]?.id ?? null) : null;
// Use real quantityAvailable from Shopify (requires unauthenticated_read_product_inventory scope).
// If null (scope not enabled), the pre-check is skipped and Shopify enforces server-side.
const quantityAvailable = !hasRealSizes ? (rawVariants[0]?.quantityAvailable ?? null) : null;

// SEO
const metaDescription = product.description
    ? product.description.slice(0, 155).replace(/\s\S*$/, "") + (product.description.length > 155 ? "…" : "")
    : `Shop the ${product.title} from Coronado Gold — handcrafted fine gold jewelry.`;

// Detect category for breadcrumb
const productHandle = (product.handle as string).toLowerCase();
const breadcrumbCategory = productHandle.includes("necklace") || productHandle.includes("collar") || productHandle.includes("chain") || productHandle.includes("cadena")
    ? { name: "Necklaces", handle: "necklaces" }
    : productHandle.includes("earring") || productHandle.includes("arete") || productHandle.includes("pendiente") || productHandle.includes("stud")
    ? { name: "Earrings", handle: "earrings" }
    : { name: "Rings", handle: "rings" };

const productSchema = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.title,
    "description": product.description || metaDescription,
    "image": mainImage?.url ?? "",
    "brand": { "@type": "Brand", "name": "Coronado Gold" },
    "offers": {
        "@type": "Offer",
        "url": `https://goldcoronado.com/products/${product.handle}/`,
        "priceCurrency": product.priceRange.minVariantPrice.currencyCode,
        "price": parseFloat(product.priceRange.minVariantPrice.amount).toFixed(2),
        "priceValidUntil": new Date(new Date().setFullYear(new Date().getFullYear() + 1)).toISOString().split("T")[0],
        "itemCondition": "https://schema.org/NewCondition",
        "availability": (quantityAvailable ?? 1) > 0
            ? "https://schema.org/InStock"
            : "https://schema.org/OutOfStock",
        "seller": { "@type": "Organization", "name": "Coronado Gold" }
    }
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://goldcoronado.com/" },
        { "@type": "ListItem", "position": 2, "name": breadcrumbCategory.name, "item": `https://goldcoronado.com/category/${breadcrumbCategory.handle}/` },
        { "@type": "ListItem", "position": 3, "name": product.title, "item": `https://goldcoronado.com/products/${product.handle}/` }
    ]
};

// Citas hardcodeadas por categoría
const CATEGORY_QUOTES = {
    rings: {
        text: "Wear a fabulous smile, great jewelry and know that you are totally and absolutely in control.",
        author: "Donatella Versace",
    },
    necklaces: {
        text: "To me, the power of a piece of jewelry is its beauty, its allure, the memory it evokes, and the way it makes me feel when I wear it.",
        author: "Carolina Herrera",
    },
    earrings: {
        text: "My jewelry represents an idea above all! I wanted to cover women with constellations.",
        author: "Coco Chanel",
    },
};

// Detecta categoría por palabras clave en el handle del producto
const handle = (product.handle as string).toLowerCase();

const categoryQuote =
    handle.includes("ring") || handle.includes("anillo")
        ? CATEGORY_QUOTES.rings
        : handle.includes("necklace") || handle.includes("collar") || handle.includes("chain") || handle.includes("cadena")
          ? CATEGORY_QUOTES.necklaces
          : handle.includes("earring") || handle.includes("pendant") || handle.includes("arete") || handle.includes("pendiente") || handle.includes("stud")
            ? CATEGORY_QUOTES.earrings
            : CATEGORY_QUOTES.rings; // fallback: siempre muestra una cita
---

<Layout title={product.title} description={metaDescription} ogImage={mainImage?.url}>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    </Fragment>
    <main class="bg-bone text-darkRed">

        <!-- ── SECTION 1: Product details ── -->
        <section class="min-h-screen w-full px-6 md:px-16 lg:px-20 pt-44 md:pt-48 lg:pt-56 pb-20 flex flex-col justify-center items-center" style="min-height: var(--app-height, 100svh);">
<div class="flex flex-col w-full md-custom:flex-row md-custom:justify-between lg:justify-center md-custom:items-start md-custom:gap-16 lg:gap-80">
            <!-- IMAGE COLUMN -->
            <div class="w-full md:w-1/2 md:max-w-2xl lg:max-w-3xl flex flex-col items-center">
                <!-- Image with corner decorations -->
                <div class="relative aspect-square w-full max-w-sm md:max-w-xl lg:max-w-2xl flex items-center justify-center p-8">
                    <Plus class="md:h-8 lg:h-6 h-4 absolute top-2 left-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute top-2 right-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute bottom-2 left-2 z-20 pointer-events-none" />
                    <Plus class="md:h-8 lg:h-6 h-4 absolute bottom-2 right-2 z-20 pointer-events-none" />

                    {mainImage?.url && (
                        <div class="relative w-full aspect-square">
                            <!-- Skeleton: ocupa el espacio antes de que la imagen cargue -->
                            <div
                                id="product-img-skeleton"
                                class="skeleton absolute inset-0 rounded-2xl transition-opacity duration-500"
                            />
                            <!-- Imagen: arranca invisible, aparece al cargar -->
                            <Image
                                id="product-main-img"
                                src={shopifyImg(mainImage.url, 1280)}
                                alt={mainImage.altText || product.title}
                                width={1280}
                                inferSize
                                class="absolute inset-0 w-full h-full object-contain drop-shadow-2xl opacity-0 transition-opacity duration-500"
                            />
                        </div>
                    )}
                </div>

                <!-- Price + CTA (mobile: below image, desktop: below image column) -->
                <p class="text-2xl md-custom:text-[clamp(2rem, 1rem+0.1vw, 3rem)] md:text-4xl lg:text-4xl tracking-widest mt-4 md:mt-6">
                    {price}
                </p>

                <div class="mt-6 md:mt-8">
                    <!-- Always active — variantId fetched at runtime if not in static props -->
<button
    id="add-to-cart-btn"
    data-variant-id={variantId ?? ""}
    data-product-handle={product.handle}
    data-product-title={product.title}
    data-price-amount={product.priceRange.minVariantPrice.amount}
    data-price-currency={product.priceRange.minVariantPrice.currencyCode}
    data-image-url={mainImage?.url ?? ""}
    data-image-alt={mainImage?.altText ?? ""}
    data-quantity-available={quantityAvailable ?? ""}
    data-has-sizes={hasRealSizes ? "true" : "false"}
    class={`
    text-darkRed! bg-linear-to-br! from-darkRed/25! via-darkRed/12! to-darkRed/8! 
        relative overflow-hidden cursor-pointer font-medium rounded-full inline-flex items-center justify-center 
        transition-all duration-300 active:scale-95 hover:scale-[1.05] 
        text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-3xl lg:text-3xl 
        py-4 px-6 md:py-6 md:px-12 lg:py-7 lg:px-14
        disabled:opacity-50 disabled:cursor-not-allowed
    `}
    style={{
        /* Fondo con gradiente para el volumen curvo */
        background: "linear-gradient(145deg, #e6e1de 0%, #dbd4d0 100%)",
        
        /* El "borde de cristal" que atrapa la luz */
        border: "1px solid rgba(255, 255, 255, 0.4)",
        
        /* Combinación de sombras: 
           1. Elevación 3D (exterior)
           2. Reflejo de luz superior (inset blanco)
           3. Sombra de profundidad (inset oscuro)
        */
        boxShadow: [
            "0 15px 25px -5px rgba(0, 0, 0, 0.12)", 
            "0 8px 10px -6px rgba(0, 0, 0, 0.1)",
            "inset 2px 2px 4px rgba(255, 255, 255, 0.7)", 
            "inset -2px -2px 5px rgba(0, 0, 0, 0.05)"
        ].join(", "),
    }}
>
    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.04] mix-blend-overlay [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span 
        class="btn-label relative z-10 uppercase tracking-[0.15em] whitespace-nowrap select-none text-[#5d2a1f]"
        style={{ textShadow: "0.5px 0.5px 0px rgba(255,255,255,0.3)" }}
    >
        Add to Cart
    </span>
</button>
                </div>
            </div>

            <!-- INFO COLUMN -->
            <div class="w-full md:w-1/2 mt-12 md-custom:mt-0 flex flex-col justify-center gap-2 md:gap-6 lg:gap-4">

               
                <!-- Title -->
                <h1 class="font-serif text-3xl md-custom:text-[clamp(2rem, 1rem+0.1vw, 3rem)] md:text-6xl  lg:text-8xl tracking-wider  leading-tight">
                    {product.title}
                </h1>

                <!-- Divider -->
                <hr class="border-darkRed/25 mt-4 mb-6 " />

                <!-- Description -->
                {product.description && (
                    <p class=" text-sm md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-2xl lg:text-3xl leading-relaxed tracking-wide  text-darkRed/80 max-w-xl lg:max-w-5xl">
                        {product.description}
                    </p>
                )}

                <!-- Size Selector -->
                {sizeVariants.length > 0 && (
                    <div id="size-selector" class="mt-6">
                        <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.2em] text-darkRed/50 uppercase mb-3">
                           Available Sizes
                        </p>
                        <div class="flex flex-wrap gap-2 md:gap-4">
                            {sizeVariants.map((v: any) => (
                                <button
                                    type="button"
                                    data-variant-id={v.id}
                                    data-size-label={v.title}
                                    data-available={v.availableForSale ? "true" : "false"}
                                    data-qty={v.quantityAvailable != null ? String(v.quantityAvailable) : ""}
                                    class={`size-btn px-4 py-2 md:px-8 md:py-4 lg:px-6 lg:py-3 text-sm md-custom:text-[clamp(0.875rem, 0.438rem+0.1vw, 0.938rem)] md:text-2xl lg:text-2xl tracking-[0.15em] rounded-lg border transition-all duration-200 select-none
                                        ${v.availableForSale
                                            ? "border-darkRed/25 text-darkRed hover:border-darkRed/60 hover:bg-darkRed/5 cursor-pointer"
                                            : "border-darkRed/10 text-darkRed/30 cursor-not-allowed line-through"
                                        }`}
                                >
                                    {v.title}
                                </button>
                            ))}
                        </div>
                       
                        <p id="size-error" class="text-xs md:text-xl lg:text-xl tracking-[0.15em] text-red-500 mt-3 uppercase hidden">
                            ⚠ Please select a size before adding to cart
                        </p>
                    </div>
                )}

                <!-- Specs table -->
                {kilates && (
                    <div class="mt-6">
                        <hr class="border-darkRed/25 mb-4" />
                        <!-- Header -->
                        <div class="grid grid-cols-2 gap-x-8">
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.2em]  text-darkRed/50 pb-3">Feature</p>
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.2em]  text-darkRed/50 pb-3">Specification</p>
                        </div>
                        <hr class="border-darkRed/25" />
                        <!-- Row: Kilates -->
                        <div class="grid grid-cols-2 gap-x-8 py-3">
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.15em] ">K</p>
                            <p class="text-xs md-custom:text-[clamp(1rem, 0.5rem+0.1vw, 1.125rem)] md:text-xl lg:text-3xl tracking-[0.15em] ">{kilates}</p>
                        </div>
                    </div>
                )}
            </div>
        </div>
        </section>

        <div class="fixed top-28 left-6 md:top-52 md:left-20 z-30">
            <CrystalButtonInterior
                text="Back"
                onClick="__cgBack()"
                className="px-6 py-2.5 rounded-full bg-gray-400/15 border border-darkRed/20 text-darkRed tracking-widest text-sm "
            />
        </div>

        <!-- ── SECTION 2: Full-bleed hover image with quote ── -->
        {interiorImage?.url && (
            <section class="relative w-full  bg-[#D4CBC8] min-h-screen flex items-end md:items-center justify-end overflow-hidden" style="min-height: var(--app-height, 100svh);">
                <!-- Background image Desktop (hidden on mobile) -->
                <Image
                    src={shopifyImg(interiorImage.url, 1920)}
                    alt={interiorImage.altText || product.title}
                    width={1920}
                    inferSize
                    class="absolute inset-0 w-full h-full object-cover object-center hidden md:block"
                />
                <!-- Background image Mobile (fallback to desktop if no mobile image) -->
                <Image
                    src={shopifyImg((interiorImageMobile?.url ?? interiorImage.url), 800)}
                    alt={(interiorImageMobile?.altText ?? interiorImage.altText) || product.title}
                    width={800}
                    inferSize
                    class="absolute inset-0 w-full h-full object-cover object-center block md:hidden"
                />

                <!-- Quote overlay -->
                {categoryQuote && (
                    <div class="relative z-10 w-full flex justify-end items-end md:items-center px-8 pb-16 md:pb-28 lg:pb-32 md:px-20">
                        <div class="text-right max-w-xs md-custom:max-w-sm md:max-w-110 lg:max-w-2xl xl:max-w-3xl">
                            <p class="font-serif text-sm  md:text-3xl lg:text-4xl leading-relaxed tracking-wide text-darkRed  italic">
                                "{categoryQuote.text}"
                            </p>
                            <p class="font-serif text-xs  md:text-3xl lg:text-4xl tracking-widest text-darkRed/70 mt-3 ">
                                — {categoryQuote.author}
                            </p>
                        </div>
                    </div>
                )}
            </section>
        )}

    </main>
</Layout>

<script>
    // Fetches the first variant ID for a product handle via Storefront API
    async function fetchVariantId(handle: string): Promise<string | null> {
        const cfg = (window as any).__SHOPIFY_CONFIG__;
        if (!cfg) return null;
        try {
            const res = await fetch(
                `https://${cfg.domain}/api/2024-01/graphql.json`,
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Shopify-Storefront-Access-Token": cfg.token,
                    },
                    body: JSON.stringify({
                        query: `query getVariant($handle: String!) {
                            productByHandle(handle: $handle) {
                                variants(first: 1) { edges { node { id } } }
                            }
                        }`,
                        variables: { handle },
                    }),
                }
            );
            const json = await res.json();
            return (
                json.data?.productByHandle?.variants?.edges?.[0]?.node?.id ?? null
            );
        } catch {
            return null;
        }
    }

    // ─── Size selector ────────────────────────────────────────────────────────
    function initSizeSelector() {
        const sizeSelector = document.getElementById("size-selector");
        if (!sizeSelector) return;

        const sizeBtns = sizeSelector.querySelectorAll<HTMLButtonElement>(".size-btn");
        const sizeHint = document.getElementById("size-hint");
        const sizeError = document.getElementById("size-error");

        sizeBtns.forEach((btn) => {
            if (btn.dataset.available === "false") return; // skip unavailable
            btn.addEventListener("click", () => {
                // Deselect all
                sizeBtns.forEach((b) => {
                    b.style.backgroundColor = "";
                    b.style.borderColor = "";
                    b.style.fontWeight = "";
                });
                // Select this one
                btn.style.backgroundColor = "rgba(104, 21, 10, 0.12)";
                btn.style.borderColor = "rgba(104, 21, 10, 0.7)";
                btn.style.fontWeight = "500";

                // Update add-to-cart btn — query at click time so we always
                // get the live node (even after cloneNode replacement)
                const addBtn = document.getElementById("add-to-cart-btn") as HTMLButtonElement | null;
                if (addBtn) {
                    addBtn.dataset.variantId = btn.dataset.variantId ?? "";
                    // Sync inventory limit to the selected size's stock
                    addBtn.dataset.quantityAvailable = btn.dataset.qty ?? "";
                }

                // Hide error, update hint
                if (sizeError) sizeError.classList.add("hidden");
                if (sizeHint) sizeHint.textContent = btn.dataset.sizeLabel ?? "";

                // Reset red border on selector
                sizeSelector.style.borderColor = "";
                sizeSelector.style.padding = "";
                sizeSelector.style.borderRadius = "";
                sizeSelector.style.borderWidth = "";
                sizeSelector.style.borderStyle = "";
            });
        });
    }

    function initAddToCart() {
        const btn = document.getElementById(
            "add-to-cart-btn"
        ) as HTMLButtonElement | null;
        if (!btn) return;

        // Clone to remove any previously bound listeners (view transitions)
        const fresh = btn.cloneNode(true) as HTMLButtonElement;
        btn.parentNode?.replaceChild(fresh, btn);

        fresh.addEventListener("click", async () => {
            const title = fresh.dataset.productTitle ?? "";
            const handle = fresh.dataset.productHandle ?? "";
            let variantId = fresh.dataset.variantId ?? "";
            const hasSizes = fresh.dataset.hasSizes === "true";

            // ── Validate size selection ──────────────────────────────────────
            if (hasSizes && !variantId) {
                const sizeSelector = document.getElementById("size-selector");
                const sizeError = document.getElementById("size-error");
                if (sizeSelector) {
                    sizeSelector.style.borderStyle = "solid";
                    sizeSelector.style.borderWidth = "1.5px";
                    sizeSelector.style.borderColor = "rgb(239 68 68)";
                    sizeSelector.style.borderRadius = "0.5rem";
                    sizeSelector.style.padding = "0.75rem";
                    // Scroll into view
                    sizeSelector.scrollIntoView({ behavior: "smooth", block: "center" });
                }
                if (sizeError) sizeError.classList.remove("hidden");
                return;
            }

            // Build product data for the optimistic cart update
            const priceAmount = fresh.dataset.priceAmount ?? "";
            const priceCurrency = fresh.dataset.priceCurrency ?? "USD";
            const imageUrl = fresh.dataset.imageUrl ?? "";
            const imageAlt = fresh.dataset.imageAlt ?? "";
            const qtyAvailable = fresh.dataset.quantityAvailable
                ? parseInt(fresh.dataset.quantityAvailable, 10)
                : null;

            fresh.disabled = true;
            const label = fresh.querySelector(".btn-label");
            if (label) label.textContent = "Adding…";

            // Fallback: fetch variant ID from Shopify if not in static data
            if (!variantId && handle) {
                variantId = (await fetchVariantId(handle)) ?? "";
                if (variantId) {
                    fresh.dataset.variantId = variantId;
                }
            }

            if (!variantId) {
                if (label) label.textContent = "Not available";
                setTimeout(() => {
                    fresh.disabled = false;
                    if (label) label.textContent = "Add to Cart";
                }, 2000);
                return;
            }

            window.dispatchEvent(
                new CustomEvent("addToCart", {
                    detail: {
                        variantId,
                        title,
                        price: priceAmount
                            ? { amount: priceAmount, currencyCode: priceCurrency }
                            : null,
                        image: imageUrl
                            ? { url: imageUrl, altText: imageAlt }
                            : null,
                        quantityAvailable: qtyAvailable,
                    },
                })
            );

            setTimeout(() => {
                fresh.disabled = false;
                if (label) label.textContent = "Add to Cart";
            }, 1800);
        });
    }

    // initAddToCart must run first (clones the button), then initSizeSelector
    // so that size clicks always find the live cloned node by ID
    initAddToCart();
    initSizeSelector();
    document.addEventListener("astro:page-load", () => {
        initAddToCart();
        initSizeSelector();
    });

    // ─── Skeleton de imagen principal ────────────────────────────────────────
    function initImageSkeleton() {
        const img = document.getElementById("product-main-img") as HTMLImageElement | null;
        const skeleton = document.getElementById("product-img-skeleton");
        if (!img || !skeleton) return;

        function reveal() {
            img!.classList.remove("opacity-0");
            img!.classList.add("opacity-100");
            skeleton!.classList.add("opacity-0", "pointer-events-none");
        }

        if (img.complete && img.naturalWidth > 0) {
            // La imagen ya estaba en caché
            reveal();
        } else {
            img.addEventListener("load", reveal, { once: true });
        }
    }

    initImageSkeleton();
    document.addEventListener("astro:page-load", initImageSkeleton);
</script>
