---
import { Image } from "astro:assets";
import CrystalButtonDark from "./helpers/CrystalButtonDark.astro";

import ringImg from "../assets/categories-ring.jpg";
import earringImg from "../assets/categories-earring.jpg";
import braceletImg from "../assets/categories-bracelet.jpg";
import chainImg from "../assets/categories-chain.jpg";

import ringMob from "../assets/categories-ring-mobile.jpg";
import earringMob from "../assets/categories-earring-mobile.jpg";
import braceletMob from "../assets/categories-bracelet-mobile.jpg";
import chainMob from "../assets/categories-chain-mobile.jpg";

const initialImages = [
    { desktop: ringImg, mobile: ringMob, alt: "Rings", handle: "rings" },
    {
        desktop: earringImg,
        mobile: earringMob,
        alt: "Earrings",
        handle: "earrings",
    },
    {
        desktop: braceletImg,
        mobile: braceletMob,
        alt: "Bracelets",
        handle: "bracelets",
    },
    {
        desktop: chainImg,
        mobile: chainMob,
        alt: "Necklaces",
        handle: "necklaces",
    },
];

const SHOPIFY_DOMAIN = import.meta.env.SHOPIFY_DOMAIN;
const STOREFRONT_ACCESS_TOKEN = import.meta.env.STOREFRONT_ACCESS_TOKEN;

const query = `
  query checkCollections {
    rings: collection(handle: "rings") {
      products(first: 1) { edges { node { id } } }
    }
    earrings: collection(handle: "earrings") {
      products(first: 1) { edges { node { id } } }
    }
    bracelets: collection(handle: "bracelets") {
      products(first: 1) { edges { node { id } } }
    }
    necklaces: collection(handle: "necklaces") {
      products(first: 1) { edges { node { id } } }
    }
  }
`;

let validData = {};
try {
    const response = await fetch(
        `https://${SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
        {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                "X-Shopify-Storefront-Access-Token": STOREFRONT_ACCESS_TOKEN,
            },
            body: JSON.stringify({ query }),
        },
    );
    const json = await response.json();
    validData = json.data || {};
} catch (error) {
    console.error("Error fetching collections for Categories:", error);
}

const images = initialImages.filter((img) => {
    const col = validData[img.handle];
    return (
        col &&
        col.products &&
        col.products.edges &&
        col.products.edges.length > 0
    );
});

// Fallback in case none are left or API fails
if (images.length === 0) {
    images.push(initialImages[0]);
}

// Extraemos datos para el JS
const categoryData = images.map((img) => ({
    alt: img.alt,
    handle: img.handle,
}));
---

<section
    id="categories"
    class="relative w-full h-screen overflow-hidden"
    data-categories={JSON.stringify(categoryData)}
>
    <div class="swiper swiper-categories absolute inset-0 z-0">
        <div class="swiper-wrapper">
            {
                images.map((img) => (
                    <div class="swiper-slide w-full h-full relative">
                        <Image
                            src={img.desktop}
                            alt={img.alt}
                            class="hidden md:block w-full h-full object-center object-cover"
                            quality={95}
                        />
                        <Image
                            src={img.mobile}
                            alt={img.alt}
                            class="block md:hidden w-full h-full object-cover"
                        />
                        <div class="absolute inset-0 bg-linear-to-b from-[#CEC8C3] from-70% to-[#D8D0C7] opacity-40 mix-blend-multiply" />
                    </div>
                ))
            }
        </div>
    </div>

    <div
        class="absolute top-1/2 -translate-y-1/2 left-1/2 -translate-x-1/2 w-full p-6 md:p-10 lg:p-20 z-10 flex justify-between items-end text-white"
    >
        <CrystalButtonDark
            id="open-side-menu"
            text="See All Categories"
            href="#"
            className="w-fit"
        />
        <div class="flex flex-col gap-10 items-end">
            <h2
                id="dynamic-title"
                class="absolute md:relative md:right-0 right-6 top-1/2 -translate-y-[200%] md:translate-y-0 text-5xl md:text-9xl lg:text-8xl transition-opacity duration-500 ease-in-out opacity-100"
            >
                {images[0].alt}
            </h2>
            <CrystalButtonDark
                id="dynamic-link"
                text="See All"
                href={`/category/${images[0].handle}`}
                className=" "
            />
        </div>
    </div>
</section>

<!-- Side Menu Backdrop -->
<div
    id="side-menu-backdrop"
    class="fixed inset-0 z-[440] bg-black/20 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-700 ease-in-out"
>
</div>

<!-- Side Menu Panel -->
<aside
    id="categories-side-menu"
    class="fixed top-0 bottom-0 left-0 w-full md:w-142 lg:w-150 z-[450] bg-[#2D1B15]/60 backdrop-blur-3xl border-r border-[#ece5e0]/20 transform -translate-x-full transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] flex flex-col justify-between py-36 md:py-52 lg:py-52 p-8 md:p-12 lg:p-16"
>
    <button
        id="close-side-menu"
        class="text-white/90 hover:text-white tracking-[0.2em] uppercase flex items-center gap-4 mb-20 transition-colors w-fit px-4 group"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6 md:w-12 md:h-12 lg:w-10 lg:h-10 transform group-hover:-translate-x-2 transition-transform duration-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.2"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
        </svg>
        <span class="text-base md:text-3xl lg:text-4xl">Back</span>
    </button>

    <nav class="flex flex-col gap-10 px-8 mt-4">
        {
            images.map((img) => (
                <a
                    href={`/category/${img.handle}`}
                    class="text-white/90 hover:text-white transition-colors lg:text-4xl text-2xl md:text-4xl w-fit relative after:content-[''] after:absolute after:-bottom-2 after:left-0 after:w-0 after:h-[1px] after:bg-white after:transition-all after:duration-300 hover:after:w-full"
                >
                    {img.alt}
                </a>
            ))
        }
    </nav>
</aside>

<script>
    import Swiper from "swiper";
    import { Autoplay, EffectFade } from "swiper/modules";

    import "swiper/css";
    import "swiper/css/effect-fade";

    let categoriesSwiper: any = null;
    let originalCategoriesHTML: string | null = null;

    const initSwiper = () => {
        const section = document.querySelector("#categories");
        const swiperEl = document.querySelector<HTMLElement>(".swiper-categories");
        const titleEl = document.querySelector("#dynamic-title");
        const linkEl = document.querySelector(
            "#dynamic-link",
        ) as HTMLAnchorElement;

        if (!swiperEl || !section || !titleEl) return;

        // Primera vez: guardar HTML limpio del servidor
        if (originalCategoriesHTML === null) {
            originalCategoriesHTML = swiperEl.innerHTML;
        } else {
            // Reinit: destruir y restaurar HTML limpio
            if (categoriesSwiper) {
                try { categoriesSwiper.destroy(true, false); } catch (_) {}
                categoriesSwiper = null;
            }
            swiperEl.innerHTML = originalCategoriesHTML;
        }

        // Side Menu Logic
        const openBtn = document.querySelector("#open-side-menu");
        const closeBtn = document.querySelector("#close-side-menu");
        const sideMenu = document.querySelector("#categories-side-menu");
        const backdrop = document.querySelector("#side-menu-backdrop");

        if (openBtn && closeBtn && sideMenu && backdrop) {
            openBtn.addEventListener("click", (e) => {
                e.preventDefault();
                sideMenu.classList.remove("-translate-x-full");
                backdrop.classList.remove("opacity-0", "pointer-events-none");
                document.dispatchEvent(new CustomEvent("sideMenuOpen"));
            });

            const closeMenu = () => {
                sideMenu.classList.add("-translate-x-full");
                backdrop.classList.add("opacity-0", "pointer-events-none");
                document.dispatchEvent(new CustomEvent("sideMenuClose"));
            };

            closeBtn.addEventListener("click", closeMenu);
            backdrop.addEventListener("click", closeMenu);
        }

        // Obtenemos los nombres desde el atributo data
        const categories = JSON.parse(
            section.getAttribute("data-categories") ?? "[]",
        );

        categoriesSwiper = new Swiper(".swiper-categories", {
            modules: [Autoplay, EffectFade],
            loop: true,
            effect: "fade",
            speed: 2000,
            autoplay: {
                delay: 4000,
                disableOnInteraction: false,
            },
            allowTouchMove: false,
            fadeEffect: {
                crossFade: true,
            },
            on: {
                slideChange: function () {
                    titleEl.classList.add("!opacity-0");
                    setTimeout(() => {
                        const currentCat = categories[categoriesSwiper.realIndex];
                        titleEl.textContent = currentCat.alt;
                        if (linkEl) {
                            linkEl.href = `/category/${currentCat.handle}`;
                        }
                        titleEl.classList.remove("!opacity-0");
                    }, 500);
                },
            },
        });
    };

    initSwiper();
    document.addEventListener("astro:page-load", initSwiper);
</script>

<style>
    .swiper-categories {
        width: 100%;
        height: 100vh;
    }

    /* Opcional: un ajuste extra de suavidad para el texto */
    #dynamic-title {
        will-change: opacity;
    }
</style>
