---
import CrystalButton from "./helpers/CrystalButton.astro";
import { Image } from "astro:assets";

const shopifyImg = (url: string, maxWidth: number) => {
    if (!url) return url;
    try {
        const u = new URL(url);
        u.searchParams.set("width", String(maxWidth));
        return u.toString();
    } catch {
        return url;
    }
};

const SHOPIFY_DOMAIN = import.meta.env.SHOPIFY_DOMAIN;
const STOREFRONT_ACCESS_TOKEN = import.meta.env.STOREFRONT_ACCESS_TOKEN;

const query = `
  query getProductsByCollection {
    collection(handle: "rings") {
      products(first: 8) {
        edges {
          node {
            id
            title
            handle
            priceRange {
              minVariantPrice {
                amount
                currencyCode
              }
            }
            images(first: 1) {
              edges {
                node {
                  url
                  altText
                }
              }
            }
            hoverImage: metafield(namespace: "custom", key: "hover_image") {
              reference {
                ... on MediaImage {
                  image {
                    url
                    altText
                  }
                }
              }
            }
          }
        }
      }
    }
  }
`;

const response = await fetch(
    `https://${SHOPIFY_DOMAIN}/api/2024-01/graphql.json`,
    {
        method: "POST",
        headers: {
            "Content-Type": "application/json",
            "X-Shopify-Storefront-Access-Token": STOREFRONT_ACCESS_TOKEN,
        },
        body: JSON.stringify({ query }),
    },
);

const json = await response.json();

// Debug: muestra en consola la respuesta de Shopify al compilar
console.log(
    "[MostPopular] Shopify response:",
    JSON.stringify(json?.data, null, 2),
);

const products = json.data?.collection?.products?.edges || [];
---

<section
    id="most-popular"
    class="relative w-full h-screen min-h-150 md:min-h-300 bg-bone overflow-hidden flex flex-col justify-center pt-[3.44rem]"
    data-products={JSON.stringify(products)}
>
    <div
        class="w-full h-full md:min-h-250 min-h-100 max-h-[70%] md:max-h-[70%] xl:max-h-[60%] 2xl:max-h-[60%] flex flex-col items-center justify-evenly"
    >
        <h2
            class="text-3xl md-custom:text-5xl md:text-8xl lg:text-7xl text-darkRed tracking-widest z-10"
        >
            Most Popular
        </h2>

        <!-- Flechas de navegación crystal -->
        <div
            class="relative w-[90%] md-custom:w-[90%] md:w-4/5 lg:w-4/5 flex items-center justify-center px-6 md:px-16 lg:px-20"
        >
            <!-- Prev -->
            <button
                id="popular-prev"
                aria-label="Previous"
                class="crystal-arrow absolute left-0 z-30 flex items-center justify-center rounded-full"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
            </button>

            <div class="swiper swiper-popular w-full">
                <div class="swiper-wrapper flex items-center">
                    {
                        products.map(({ node: product }) => (
                            <div class="scale-60 swiper-slide flex items-center justify-center aspect-square ">
                                <a
                                    href={`/products/${product.handle}`}
                                    class="w-full relative group h-full rounded-full flex items-center justify-center transition-all duration-700 image-container cursor-pointer"
                                >
                                    {product.hoverImage?.reference?.image
                                        ?.url && (
                                        <Image
                                            src={shopifyImg(
                                                product.hoverImage.reference
                                                    .image.url,
                                                800,
                                            )}
                                            alt={
                                                product.hoverImage.reference
                                                    .image.altText ||
                                                product.title
                                            }
                                            width={800}
                                            inferSize
                                            class="absolute inset-0 w-full aspect-square h-full object-cover object-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 ease-in-out z-10"
                                        />
                                    )}
                                    <Image
                                        src={shopifyImg(
                                            product.images.edges[0]?.node.url,
                                            800,
                                        )}
                                        alt={
                                            product.images.edges[0]?.node
                                                .altText || product.title
                                        }
                                        width={800}
                                        inferSize
                                        class="relative w-full aspect-square h-full object-cover object-center group-hover:opacity-0 transition-opacity duration-500 ease-in-out"
                                    />
                                </a>
                            </div>
                        ))
                    }
                </div>
            </div>

            <!-- Next -->
            <button
                id="popular-next"
                aria-label="Next"
                class="crystal-arrow absolute right-0 z-30 flex items-center justify-center rounded-full"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                >
                    <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
            </button>
        </div><!-- end carousel wrapper -->

        <div class="text-center z-10 px-8 md:px-16 lg:px-20">
            <h3
                id="active-title"
                class="text-xl md-custom:text-2xl md:text-5xl lg:text-4xl text-darkRed tracking-wide transition-opacity duration-500"
            >
                {products[0]?.node.title}
            </h3>

            <p
                id="active-price"
                class="text-lg md-custom:text-2xl font-bold md:text-5xl lg:text-4xl text-darkRed/80 tracking-wide mt-2 md:mt-4 mb-4 md:mb-8 transition-opacity duration-500"
            >
                {
                    products[0] &&
                        new Intl.NumberFormat("en-US", {
                            style: "currency",
                            currency:
                                products[0].node.priceRange.minVariantPrice
                                    .currencyCode,
                        }).format(
                            parseFloat(
                                products[0].node.priceRange.minVariantPrice
                                    .amount,
                            ),
                        )
                }
            </p>
            <div
                class="swiper-pagination-popular mb-4 flex justify-center gap-2"
            >
            </div>
            <CrystalButton
                id="active-link"
                text="See Details"
                href={`/products/${products[0]?.node.handle}`}
                className="text-darkRed! mt-8 bg-linear-to-br! from-darkRed/25! via-darkRed/12! to-darkRed/8! "
            />
        </div>
    </div>
</section>

<style>
    /* ── Crystal arrows ────────────────────────────────────────────────────── */
    .crystal-arrow {
        width: 2.8rem;
        height: 2.8rem;
        cursor: pointer;
        color: #79180b;
        background: linear-gradient(145deg, #e6e1de 0%, #dbd4d0 100%);
        border: 1px solid rgba(255, 255, 255, 0.4);
        box-shadow:
            0 15px 25px -5px rgba(0, 0, 0, 0.12),
            0 8px 10px -6px rgba(0, 0, 0, 0.1),
            inset 2px 2px 4px rgba(255, 255, 255, 0.7),
            inset -2px -2px 5px rgba(0, 0, 0, 0.05);
        transform: scale(1);
        transition:
            transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
            box-shadow 0.25s ease;
    }

    .crystal-arrow:hover {
        transform: scale(1.1);
        box-shadow:
            0 20px 30px -5px rgba(0, 0, 0, 0.16),
            0 10px 14px -6px rgba(0, 0, 0, 0.12),
            inset 2px 2px 5px rgba(255, 255, 255, 0.8),
            inset -2px -2px 6px rgba(0, 0, 0, 0.06);
    }

    .crystal-arrow:active {
        transform: scale(0.95);
    }

    .crystal-arrow svg {
        width: 1.2rem;
        height: 1.2rem;
    }

    @media (min-width: 768px) {
        .crystal-arrow {
            width: 6.5rem;
            height: 6.5rem;
            left: auto;
            right: auto;
        }
        #popular-prev {
            left: -1.25rem;
        }
        #popular-next {
            right: -1.25rem;
        }
        .crystal-arrow svg {
            width: 2.8rem;
            height: 2.8rem;
        }
    }

    @media (min-width: 1024px) {
        .crystal-arrow {
            width: 5.5rem;
            height: 5.5rem;
        }
        #popular-prev {
            left: -1.75rem;
        }
        #popular-next {
            right: -1.75rem;
        }
        .crystal-arrow svg {
            width: 2.6rem;
            height: 2.6rem;
        }
    }

    /* Contenedor de paginación */
    .swiper-pagination-popular {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
    }

    /* Estilo base de los puntos (inactivos) */
    :global(.swiper-pagination-popular .swiper-pagination-bullet) {
        width: 0.4rem;
        height: 0.4rem;
        background-color: #d1d1d1; /* Gris claro de la foto */
        opacity: 1;
        border-radius: 50%;
        transition: all 0.3s ease;
        cursor: pointer;
        display: inline-block;
    }

    @media (min-width: 768px) and (max-width: 1024px) {
        :global(.swiper-pagination-popular .swiper-pagination-bullet) {
            width: 0.8rem;
            height: 0.8rem;
        }
    }

    @media (min-width: 1024px) {
        :global(.swiper-pagination-popular .swiper-pagination-bullet) {
            width: 1rem;
            height: 1rem;
        }
    }

    /* Estilo del punto Activo */
    :global(.swiper-pagination-popular .swiper-pagination-bullet-active) {
        background-color: #68150a; /* El color darkRed/café de tu diseño */
        transform: scale(1.2);
    }

    /* Ocultar bullets por defecto de swiper si los hubiera */
    .swiper-pagination-lock {
        display: none !important;
    }

    .swiper-slide {
        /* Forzamos renderizado por GPU en iOS */
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        transform-style: preserve-3d;
        -webkit-transform-style: preserve-3d;

        /* Transición unificada */
        transition: all 0.5s ease-in-out;
        will-change: transform, opacity, filter;

        filter: blur(10px);
        opacity: 0.5;
        /* Usamos transform para scale por mayor compatibilidad */
        transform: scale(0.5) translateZ(0) !important;
    }

    .swiper-slide-active {
        filter: blur(0px);
        opacity: 1;
        transform: scale(1) translateZ(0) !important;
        z-index: 20;
    }

    .swiper-slide-next,
    .swiper-slide-prev {
        filter: blur(4px);
        opacity: 0.7;
        transform: scale(0.7) translateZ(0) !important;
        z-index: 10;
    }

    @media (max-width: 768px) {
        .swiper-slide {
            transform: scale(0.5) translateZ(0) !important;
        }
        .swiper-slide-active {
            transform: scale(1) translateZ(0) !important;
        }
        .swiper-slide-next,
        .swiper-slide-prev {
            transform: scale(0.5) translateZ(0) !important;
        }
    }
</style>

<script>
    import Swiper from "swiper";
    import { Autoplay, Pagination } from "swiper/modules";

    // 2. Importar los estilos necesarios para el efecto
    import "swiper/css";
    import "swiper/css/effect-coverflow";

    let popularSwiper: any = null;
    let originalPopularHTML: string | null = null;

    function initCarousel() {
        const section = document.querySelector("#most-popular");
        if (!section) return;

        const swiperEl = document.querySelector<HTMLElement>(".swiper-popular");
        if (!swiperEl) return;

        // Primera vez: guardar el HTML original limpio del servidor
        if (originalPopularHTML === null) {
            originalPopularHTML = swiperEl.innerHTML;
        } else {
            // Reinit: destruir instancia vieja y restaurar el HTML limpio
            // garantiza que Swiper arranca desde DOM virgen sin importar
            // qué haya cacheado Astro
            if (popularSwiper) {
                try {
                    popularSwiper.destroy(true, false);
                } catch (_) {}
                popularSwiper = null;
            }
            swiperEl.innerHTML = originalPopularHTML;
        }

        const edges = JSON.parse(section.getAttribute("data-products") || "[]");
        const products = edges.map((e: any) => e.node);
        const titleEl = document.getElementById("active-title");
        const priceEl = document.getElementById("active-price");
        const linkEl = document.getElementById(
            "active-link",
        ) as HTMLAnchorElement;

        popularSwiper = new Swiper(".swiper-popular", {
            // 3. Añadir el módulo a la lista
            modules: [Autoplay, Pagination],
            shortSwipes: true,
            longSwipes: false,
            grabCursor: true,
            centeredSlides: true,
            slidesPerView: 1.9, // 'auto' suele funcionar mejor con coverflow
            loop: true,
            spaceBetween: -150,
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            },
            pagination: {
                el: ".swiper-pagination-popular",
                clickable: true,
                renderBullet: function (index, className) {
                    // Creamos bullets limpios
                    return `<span class="${className}"></span>`;
                },
            },
            breakpoints: {
                768: {
                    slidesPerView: 4,
                    spaceBetween: -120,
                },
            },

            on: {
                slideChange: function (s) {
                    const activeIndex = s.realIndex;
                    const product = products[activeIndex];

                    if (product && titleEl && priceEl && linkEl) {
                        [titleEl, priceEl].forEach((el) =>
                            el.classList.add("opacity-0"),
                        );

                        setTimeout(() => {
                            titleEl.textContent = product.title;
                            priceEl.textContent = new Intl.NumberFormat(
                                "en-US",
                                {
                                    style: "currency",
                                    currency:
                                        product.priceRange.minVariantPrice
                                            .currencyCode,
                                },
                            ).format(
                                parseFloat(
                                    product.priceRange.minVariantPrice.amount,
                                ),
                            );
                            linkEl.href = `/products/${product.handle}`;

                            [titleEl, priceEl].forEach((el) =>
                                el.classList.remove("opacity-0"),
                            );
                        }, 400);
                    }
                },
            },
        });
    }

    // ── Arrow navigation ──────────────────────────────────────────────────────
    function initArrows() {
        const prev = document.getElementById("popular-prev");
        const next = document.getElementById("popular-next");
        if (!prev || !next) return;

        // Clonar para eliminar listeners anteriores (view transitions)
        const freshPrev = prev.cloneNode(true) as HTMLElement;
        const freshNext = next.cloneNode(true) as HTMLElement;
        prev.parentNode?.replaceChild(freshPrev, prev);
        next.parentNode?.replaceChild(freshNext, next);

        freshPrev.addEventListener("click", () => popularSwiper?.slidePrev());
        freshNext.addEventListener("click", () => popularSwiper?.slideNext());
    }

    initCarousel();
    document.addEventListener("astro:page-load", () => {
        initCarousel();
        initArrows();
    });

    // Inicializar flechas después del carrusel en carga inicial
    initArrows();
</script>
