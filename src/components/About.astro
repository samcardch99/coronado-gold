---
import { Image } from "astro:assets";
import aboutImage1 from "../assets/about-1.jpg";
import aboutImage2 from "../assets/about-2.jpg";
---

<section
    id="about"
    class="relative w-full min-h-150 h-screen overflow-hidden flex items-center bg-bone"
>
    <div
        class="w-full h-fit flex flex-col gap-28 md:gap-68 lg:gap-20 p-6 md:p-16 md:pt-32 lg:p-20 lg:pt-44"
    >
        <div
            class="flex flex-col items-end justify-center w-full h-[40vw] max-h-[30vh] md:max-h-max md-custom:h-[40vh] lg:h-[50vh] 2xl-prev:h-[60vh] mt-12 gap-4 md:gap-8 lg:gap-12"
        >
            <div
                class="flex gap-4 md:gap-8 items-end justify-end flex-1 min-h-0 h-full"
            >
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                    style="--reveal-delay: 0ms"
                >
                    The
                </h2>
                <Image
                    quality={100}
                    src={aboutImage1}
                    alt="about image 1"
                    class="about-reveal h-full w-fit object-contain"
                    style="--reveal-delay: 150ms"
                />
            </div>
            <div
                class="flex gap-4 md:gap-8 items-center justify-end flex-1 min-h-0 h-full"
            >
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                    style="--reveal-delay: 300ms"
                >
                    Legacy
                </h2>
                <Image
                    quality={100}
                    src={aboutImage2}
                    alt="about image 2"
                    class="about-reveal h-full w-fit object-contain"
                    style="--reveal-delay: 450ms"
                />
            </div>
            <div class="flex gap-4 md:gap-8 items-start flex-1 min-h-0 h-full">
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                    style="--reveal-delay: 600ms"
                >
                    of excellence
                </h2>
            </div>
        </div>

        {/* Eliminamos los spans manuales y dejamos el texto limpio */}
        <p
            id="about-para"
            class="text-black text-sm md:text-4xl lg:text-3xl w-full md:w-3/5 xl:w-2/5 leading-[1.4]"
        >
            Coronado Gold focuses on the curation and trade of high-purity gold
            jewelry. The proposition is straightforward: pieces with a
            technically and structurally solid design, where the true value of
            the metal takes center stage.
        </p>
    </div>
</section>

<style is:global>
    /* Estilos para las líneas generadas dinámicamente */
    .line-mask {
        display: block;
        overflow: hidden;
    }

    .line-content {
        display: block;
        opacity: 0;
        transform: translateY(100%);
        transition:
            transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.6s linear;
    }

    .lines-visible .line-content {
        opacity: 1;
        transform: translateY(0);
        transition-delay: calc(800ms + (var(--line-index) * 150ms));
    }

    .about-reveal {
        opacity: 0;
        transform: translateX(80px);
        transition:
            opacity 1.2s cubic-bezier(0.22, 1, 0.36, 1),
            transform 1.2s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--reveal-delay, 0ms);
    }

    .about-reveal.is-visible {
        opacity: 1;
        transform: translateX(0);
    }
</style>

<script>
    function splitTextIntoLines() {
        const para = document.getElementById("about-para");
        if (!para) return;

        const text = para.innerText;
        const words = text.split(" ");
        para.innerHTML = "";

        // Creamos un contenedor temporal para medir líneas
        let currentLine = document.createElement("span");
        currentLine.className = "line-mask";
        let innerSpan = document.createElement("span");
        innerSpan.className = "line-content";
        currentLine.appendChild(innerSpan);
        para.appendChild(currentLine);

        let lineCount = 0;
        let lastHeight = 0;

        words.forEach((word, index) => {
            const previousHTML = innerSpan.innerHTML;
            innerSpan.innerHTML += (index === 0 ? "" : " ") + word;

            // Si la altura cambia, significa que la palabra saltó de línea
            if (innerSpan.offsetHeight > lastHeight && index !== 0) {
                // Deshacemos el cambio en la línea actual
                innerSpan.innerHTML = previousHTML;

                // Creamos nueva línea
                lineCount++;
                currentLine = document.createElement("span");
                currentLine.className = "line-mask";
                innerSpan = document.createElement("span");
                innerSpan.className = "line-content";
                innerSpan.style.setProperty(
                    "--line-index",
                    lineCount.toString(),
                );
                innerSpan.innerHTML = word;
                currentLine.appendChild(innerSpan);
                para.appendChild(currentLine);
            }

            lastHeight = innerSpan.offsetHeight;
            if (index === 0) innerSpan.style.setProperty("--line-index", "0");
        });
    }

    function init() {
        const section = document.getElementById("about");
        const para = document.getElementById("about-para");

        // Primero dividimos el texto según el ancho actual del dispositivo
        splitTextIntoLines();

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        section
                            ?.querySelectorAll(".about-reveal")
                            .forEach((el) => el.classList.add("is-visible"));
                        para?.classList.add("lines-visible");
                        observer.disconnect();
                    }
                });
            },
            { threshold: 0.2 },
        );

        if (section) observer.observe(section);
    }

    // Ejecutar en carga inicial y en cambios de página (Astro)
    init();
    document.addEventListener("astro:page-load", init);

    // Opcional: Re-calcular si el usuario rota el teléfono o cambia el tamaño de ventana
    let resizeTimer: any;
    window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(init, 250);
    });
</script>
