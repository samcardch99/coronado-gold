---
import { Image } from "astro:assets";
import aboutImage1 from "../assets/about-1.jpg";
import aboutImage2 from "../assets/about-2.jpg";
---

<section
    id="about"
    class="relative w-full overflow-hidden flex items-center bg-bone"
    style="min-height: 600px; height: 100vh; height: 100svh;"
>
    <div
        class="w-full flex flex-col gap-12 md:justify-between md:h-[70vh] lg:h-auto lg:gap-20 p-6 md:p-16 md:pt-32 lg:p-20 lg:pt-44"
    >
        <div
            class="grid grid-rows-3 items-end justify-items-end w-full h-[40vw] max-h-[30vh] md:max-h-30vh] lg:max-h-max md-custom:h-[40vh] lg:h-[50vh] 2xl:h-[50vh] mt-12 gap-4 md:gap-8 lg:gap-12"
        >
            <!-- Row 1: The + image1 -->
            <div
                class="flex gap-4 md:gap-8 items-end justify-end w-full h-full min-h-0"
            >
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] md:text-[4vh] lg:text-[8vh] 2xl:text-8xl text-darkRed"
                    style="--reveal-delay: 0ms"
                >
                    The
                </h2>
                <Image
                    quality={100}
                    src={aboutImage1}
                    alt="about image 1"
                    class="about-reveal w-auto object-contain"
                    style="--reveal-delay: 150ms; height: 100%; max-height: 100%; display: block;"
                />
            </div>
            <!-- Row 2: Legacy + image2 -->
            <div
                class="flex gap-4 md:gap-8 items-center justify-end w-full h-full min-h-0"
            >
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] md:text-[4vh] lg:text-[8vh] 2xl:text-8xl text-darkRed"
                    style="--reveal-delay: 300ms"
                >
                    Legacy
                </h2>
                <Image
                    quality={100}
                    src={aboutImage2}
                    alt="about image 2"
                    class="about-reveal w-auto object-contain"
                    style="--reveal-delay: 450ms; height: 100%; max-height: 100%; display: block;"
                />
            </div>
            <!-- Row 3: of excellence -->
            <div
                class="flex gap-4 md:gap-8 items-start justify-end w-full h-full min-h-0"
            >
                <h2
                    class="about-reveal text-[clamp(1.5rem,5vw,2rem)] leading-none md-custom:text-[6vh] md:text-[4vh] lg:text-[8vh] 2xl:text-8xl text-darkRed"
                    style="--reveal-delay: 600ms"
                >
                    of excellence
                </h2>
            </div>
        </div>

        <p
            id="about-para"
            class="text-black text-sm md:text-4xl lg:text-3xl w-full md:w-3/5 xl:w-2/5 leading-[1.4]"
        >
            Coronado Gold focuses on the curation and trade of high-purity gold
            jewelry. The proposition is straightforward: pieces with a
            technically and structurally solid design, where the true value of
            the metal takes center stage.
        </p>
    </div>
</section>

<style is:global>
    /* Estilos optimizados para Safari/iOS */
    .line-mask {
        display: block;
        overflow: hidden;
        /* El padding previene que Safari corte las descendentes (letras j, g, p) */
        padding-bottom: 0.2em;
        margin-bottom: -0.2em;
    }

    .line-content {
        display: inline-block;
        width: 100%;
        opacity: 0;
        transform: translateY(110%);
        transition:
            transform 0.8s cubic-bezier(0.22, 1, 0.36, 1),
            opacity 0.8s linear;
        /* Aceleración de hardware para suavidad en iPhone */
        will-change: transform;
        -webkit-font-smoothing: antialiased;
    }

    .lines-visible .line-content {
        opacity: 1;
        transform: translateY(0);
        transition-delay: calc(600ms + (var(--line-index) * 120ms));
    }

    .about-reveal {
        opacity: 0;
        transform: translateX(60px);
        transition:
            opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
            transform 1s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: transform, opacity;
    }

    .about-reveal.is-visible {
        opacity: 1;
        transform: translateX(0);
    }
</style>

<script>
    function splitTextIntoLines() {
        const para = document.getElementById("about-para");
        if (!para) return;

        const text = para.innerText;
        const words = text.split(/\s+/);
        para.innerHTML = "";

        let lineCount = 0;
        let currentLine = document.createElement("span");
        currentLine.className = "line-mask";

        let innerSpan = document.createElement("span");
        innerSpan.className = "line-content";
        innerSpan.style.setProperty("--line-index", "0");

        currentLine.appendChild(innerSpan);
        para.appendChild(currentLine);

        // Medir altura inicial
        innerSpan.innerHTML = words[0];
        let lastHeight = innerSpan.getBoundingClientRect().height;

        words.forEach((word, index) => {
            if (index === 0) return;

            const previousHTML = innerSpan.innerHTML;
            innerSpan.innerHTML += " " + word;

            // getBoundingClientRect es crucial para Safari (subpíxeles)
            const currentHeight = innerSpan.getBoundingClientRect().height;

            // Margen de tolerancia de 5px para detectar salto de línea real
            if (currentHeight > lastHeight + 5) {
                innerSpan.innerHTML = previousHTML;

                lineCount++;
                currentLine = document.createElement("span");
                currentLine.className = "line-mask";

                innerSpan = document.createElement("span");
                innerSpan.className = "line-content";
                innerSpan.style.setProperty(
                    "--line-index",
                    lineCount.toString(),
                );
                innerSpan.innerHTML = word;

                currentLine.appendChild(innerSpan);
                para.appendChild(currentLine);

                lastHeight = innerSpan.getBoundingClientRect().height;
            }
        });
    }

    async function init() {
        const section = document.getElementById("about");
        const para = document.getElementById("about-para");

        // Esperar a que las tipografías carguen para que las medidas sean exactas
        if ("fonts" in document) {
            await document.fonts.ready;
        }

        splitTextIntoLines();

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        section
                            ?.querySelectorAll(".about-reveal")
                            .forEach((el) => {
                                el.classList.add("is-visible");
                            });

                        // Pequeño delay para asegurar el render tras el split
                        setTimeout(() => {
                            para?.classList.add("lines-visible");
                        }, 50);

                        observer.disconnect();
                    }
                });
            },
            { threshold: 0.05 },
        );

        if (section) observer.observe(section);
    }

    // Compatibilidad con navegación de Astro y carga inicial
    init();
    document.addEventListener("astro:page-load", init);

    let resizeTimer: any;
    window.addEventListener("resize", () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(init, 300);
    });
</script>
