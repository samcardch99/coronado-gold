---
import { Image } from "astro:assets";
import aboutImage1 from "../assets/about-1.jpg";
import aboutImage2 from "../assets/about-2.jpg";
---

<section
    id="about"
    class="relative w-full min-h-150 h-screen overflow-hidden flex items-center bg-bone"
>
    <div
        class="w-full h-fit flex flex-col gap-28 md:gap-68 lg:gap-20 p-6 md:p-16 md:pt-32 lg:p-20 lg:pt-44"
    >
        <div
            class="flex flex-col items-end justify-center w-full h-[40vw] max-h-[30vh] md:max-h-max md-custom:h-[40vh] lg:h-[50vh] 2xl-prev:h-[60vh] mt-12 gap-4 md:gap-8 lg:gap-12"
        >
            <div
                class="flex gap-4 md:gap-8 items-end justify-end flex-1 min-h-0 h-full"
            >
                <h2
                    class="text-[clamp(1rem,1.75rem,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                >
                    The
                </h2>
                <Image
                    quality={100}
                    src={aboutImage1}
                    alt="about image 1"
                    class="h-full w-fit object-contain"
                />
            </div>
            <div
                class="flex gap-4 md:gap-8 items-center justify-end flex-1 min-h-0 h-full"
            >
                <h2
                    class="text-[clamp(1rem,1.75rem,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                >
                    Legacy
                </h2>
                <Image
                    quality={100}
                    src={aboutImage2}
                    alt="about image 2"
                    class="h-full w-fit object-contain"
                />
            </div>
            <div class="flex gap-4 md:gap-8 items-start flex-1 min-h-0 h-full">
                <h2
                    class="text-[clamp(1rem,1.75rem,2rem)] leading-none md-custom:text-[6vh] lg:text-[8vh] text-darkRed"
                >
                    of excellence
                </h2>
            </div>
        </div>
        <p
            class="text-black text-sm md:text-[clamp(2.25rem,1rem+1vw,4rem)] lg:text-3xl w-full md-custom:w-3/5 md:w-3/5 xl:w-1/3"
        >
            Coronado Gold focuses on the curation and trade of high-purity gold
            jewelry. The proposition is straightforward: pieces with a
            technically and structurally solid design, where the true value of
            the metal takes center stage.
        </p>
    </div>
</section>
