---
const { text, href, className, id } = Astro.props;
---

<a
    id={id}
    href={href}
    class={`relative overflow-hidden cursor-pointer font-medium rounded-full inline-flex items-center justify-center transition-all duration-300 active:scale-[0.98] hover:scale-[1.02]
    bg-[#2D1B15]/60 backdrop-blur-xl
    text-white! text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-[clamp(2.25rem,1rem+1.5vw,4rem)] lg:text-3xl lg:py-7 lg:px-14 py-4 px-6 md:py-6 md:px-12 ${className}`}
    style={{
        boxShadow: [
            "0px 12px 20px -4px rgba(0, 0, 0, 0.35)" /* sombra exterior de elevación */,
            "inset 0 1px 0 rgba(255,255,255,0.18)" /* borde superior brillante */,
            "inset 0 -2px 6px rgba(0, 0, 0, 0.35)" /* profundidad inferior oscura */,
            "inset 2px 0 8px rgba(255,255,255,0.04)" /* reflejo lateral izquierdo */,
        ].join(", "),
    }}
>
    {/* Highlight radial: punto de luz en la esquina superior-izquierda */}
    <span
        class="pointer-events-none absolute rounded-full z-10"
        style={{
            top: "0%",
            left: "5%",
            width: "50%",
            height: "50%",
            background:
                "radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.07) 0%, transparent 65%)",
        }}></span>

    {/* Borde con máscara: visible solo en arco superior-izquierdo */}
    <div
        class="absolute inset-0 rounded-full p-px pointer-events-none mask-[linear-gradient(135deg,black_0%,black_35%,transparent_70%)]"
    >
        <div class="absolute inset-0 rounded-full border border-white/30"></div>
    </div>

    {/* Reflejo inferior difuso (efecto profundidad) */}
    <span
        class="pointer-events-none absolute bottom-0 left-0 right-0 rounded-b-full z-1"
        style={{
            height: "40%",
            background:
                "linear-gradient(to top, rgba(0,0,0,0.25) 0%, transparent 100%)",
        }}></span>

    <span
        class="relative z-20 select-none uppercase tracking-[0.15em] whitespace-nowrap"
        style={{
            textShadow: "0 1px 3px rgba(0,0,0,0.4)",
        }}
    >
        {text}
    </span>
</a>
