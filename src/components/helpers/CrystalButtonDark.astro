---
const { text, href, className, id } = Astro.props;
---

<a
    id={id}
    href={href}
    class={`relative overflow-hidden cursor-pointer font-medium rounded-full inline-flex items-center justify-center transition-all duration-300 active:scale-[0.98] hover:scale-[1.02]
    bg-[#2D1B15]/60 backdrop-blur-xl
    text-white! text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-[clamp(2.25rem,1rem+1.5vw,4rem)] lg:text-3xl lg:py-7 lg:px-14 py-4 px-6 md:py-6 md:px-12 ${className}`}
    style={{
        border: "1px solid rgba(255, 255, 255, 0.2)",
        boxShadow: [
            "0 15px 25px -5px rgba(0, 0, 0, 0.15)",
            "0 8px 10px -6px rgba(0, 0, 0, 0.1)",
            "inset 2px 2px 4px rgba(255, 255, 255, 0.2)",
            "inset -2px -2px 5px rgba(0, 0, 0, 0.05)",
        ].join(", "),
    }}
>
    <!-- noise overlay cristal -->
    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.04] mix-blend-overlay [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span
        class="relative z-10 select-none uppercase tracking-[0.15em] whitespace-nowrap"
        style={{
            textShadow: "0 1px 3px rgba(0,0,0,0.4), 0.5px 0.5px 0px rgba(255,255,255,0.15)",
        }}
    >
        {text}
    </span>
</a>
