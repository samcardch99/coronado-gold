---
const { text, href, className, id } = Astro.props;
---

<a
    id={id}
    href={href}
    class={`relative overflow-hidden cursor-pointer font-medium rounded-full inline-flex items-center justify-center transition-all duration-300 active:scale-[0.98] hover:scale-[1.02] 
    /* Fondo oscuro glass y blur del indicator */
    bg-[#d9d9d90f] backdrop-blur-xl
    /* Tipografía y dimensiones */
    text-darkRed! text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-[clamp(2.25rem,1rem+1.5vw,4rem)] lg:text-3xl lg:py-7 lg:px-14 py-4 px-6 md:py-6 md:px-12 ${className}`}
    style={{
        /* Borde sutil blanco al 60% como en el nav */
        border: "1px solid rgba(255, 255, 255, 0.6)",

        /* 1. Sombra exterior suave 
           2. Inset superior blanco (el brillo del indicator)
        */
        boxShadow: [
            "0px 10px 15px -3px rgba(0, 0, 0, 0.2)",
            "inset 0 4px 6px rgba(255, 255, 255, 0.15)",
        ].join(", "),
    }}
>
    <div
        class="absolute inset-0 rounded-full p-px pointer-events-none mask-[linear-gradient(to_bottom_left,black_40%,transparent_50%),linear-gradient(to_top_right,black_40%,transparent_50%)]"
    >
        <div class="absolute inset-0 rounded-full border border-white/40"></div>
    </div>

    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.05] mix-blend-overlay [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span
        class="relative z-10 select-none uppercase tracking-[0.15em] whitespace-nowrap"
        style={{
            textShadow: "0.5px 0.5px 1px rgba(255,255,255,0.1)",
        }}
    >
        {text}
    </span>
</a>
