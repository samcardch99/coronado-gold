---
const { text, href, className, id } = Astro.props;
---

<a
    id={id}
    href={href}
    class={`text-[clamp(0.5rem,0.5rem+1vw,1rem)] md:text-[clamp(2.25rem,1rem+1.5vw,4rem)] lg:text-3xl lg:py-7 lg:px-12 py-4 px-4 md:py-6 md:px-10 inline-flex items-center justify-center rounded-full bg-[#D4CBC8] shadow-[0_8px_10px_rgba(0,0,0,0.30)] transition-transform duration-800 ease-[cubic-bezier(0.175,0.885,0.32,2.2)] hover:scale-[1.05] ${className}`}
    style="-webkit-backdrop-filter: url(#glass)"
>
    <!-- subtle noise overlay (replaces ::before) -->
    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.03] [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span
        class="relative z-2 select-none uppercase tracking-wider whitespace-nowrap"
    >
        {text}
    </span>
</a>

<!-- SVG filter -->
<svg style="position: absolute; width: 0; height: 0">
    <filter id="glass">
        <feTurbulence
            type="turbulence"
            baseFrequency="0.02"
            numOctaves="3"
            seed="2"
            result="turb"></feTurbulence>
        <feDisplacementMap
            in="SourceGraphic"
            in2="turb"
            scale="20"
            xChannelSelector="R"
            yChannelSelector="G"></feDisplacementMap>
    </filter>
</svg>
<style>
    /* keyframes for the floating background */
    @keyframes floatBG {
        0%,
        100% {
            background-position: center center;
        }
        25% {
            background-position: 30% 70%;
        }
        50% {
            background-position: 70% 30%;
        }
        75% {
            background-position: 40% 60%;
        }
    }
</style>
