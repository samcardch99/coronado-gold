---
const { text, onClick, className, id } = Astro.props;
---

<button
    id={id}
    onclick={onClick}
    class={`z-600 shadow-lg text-[clamp(0.7rem,0.6rem+1vw,1rem)] md:text-[clamp(2rem,0.75rem+1.5vw,3rem)] hover:cursor-pointer  lg:text-3xl  lg:py-7 lg:px-12 py-2 px-4 md:py-5 md:px-9 inline-flex  items-center justify-center rounded-full border border-white/30 bg-[#2D1B15]/60 text-[#EBE6E0] [backdrop-filter:url(#glass)] transition-transform duration-800 ease-[cubic-bezier(0.175,0.885,0.32,2.2)] hover:scale-[1.05] ${className}`}
    style="-webkit-backdrop-filter: url(#glass)"
>
    <!-- subtle noise overlay (replaces ::before) -->
    <span
        class='pointer-events-none absolute inset-0 z-1 opacity-[0.03] [background-image:url(&apos;data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%"><filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch"/></filter><rect width="100%" height="100%" filter="url(%23noise)"/></svg>&apos;)]'
    ></span>

    <span
        class="relative z-2 select-none uppercase tracking-wider whitespace-nowrap"
    >
        {text}
    </span>
</button>

<!-- SVG filter -->
<svg style="position: absolute; width: 0; height: 0">
    <filter id="glass">
        <feTurbulence
            type="turbulence"
            baseFrequency="0.02"
            numOctaves="3"
            seed="2"
            result="turb"></feTurbulence>
        <feDisplacementMap
            in="SourceGraphic"
            in2="turb"
            scale="20"
            xChannelSelector="R"
            yChannelSelector="G"></feDisplacementMap>
    </filter>
</svg>
<style>
    /* keyframes for the floating background */
    @keyframes floatBG {
        0%,
        100% {
            background-position: center center;
        }
        25% {
            background-position: 30% 70%;
        }
        50% {
            background-position: 70% 30%;
        }
        75% {
            background-position: 40% 60%;
        }
    }
</style>
