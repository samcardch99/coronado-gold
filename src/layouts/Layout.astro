---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingBar from "../components/helpers/FloatingBar.astro";
import CartSidebar from "../components/CartSidebar.jsx";

const { title } = Astro.props;

const shopifyDomain = import.meta.env.SHOPIFY_DOMAIN;
const storefrontToken = import.meta.env.STOREFRONT_ACCESS_TOKEN;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" lang="en" translate="no" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} — Coronado Gold` : "Coronado Gold"}</title>

		<!-- Inject Shopify config for client-side cart utility -->
		<script define:vars={{ shopifyDomain, storefrontToken }}>
			window.__SHOPIFY_CONFIG__ = {
				domain: shopifyDomain,
				token: storefrontToken,
			};
		</script>
	</head>
	<body>
		<Navbar />
		<FloatingBar />
		<slot />
		<Footer />

		<!-- Cart sidebar (React island, fully client-side) -->
		<CartSidebar client:load />

		<script>
			import Lenis from "lenis";
			import "lenis/dist/lenis.css";

			const lenis = new Lenis({
				autoRaf: true,
			});
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
