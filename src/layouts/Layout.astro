---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingBar from "../components/helpers/FloatingBar.astro";
import CartSidebar from "../components/CartSidebar.jsx";
import ClientRouter from "astro/components/ClientRouter.astro";

const { title } = Astro.props;

const shopifyDomain = import.meta.env.SHOPIFY_DOMAIN;
const storefrontToken = import.meta.env.STOREFRONT_ACCESS_TOKEN;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" lang="en" translate="no" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} — Coronado Gold` : "Coronado Gold"}</title>
		<ClientRouter />

		<!-- Inject Shopify config for client-side cart utility -->
		<script define:vars={{ shopifyDomain, storefrontToken }}>
			window.__SHOPIFY_CONFIG__ = {
				domain: shopifyDomain,
				token: storefrontToken,
			};
		</script>
	</head>
	<body>
		<Navbar />
		<FloatingBar />
		<slot />
		<Footer />

		<!-- Cart sidebar (React island, fully client-side) -->
		<CartSidebar client:load />

		<script>
			import Lenis from "lenis";
			import "lenis/dist/lenis.css";

			function createLenis() {
				// Destruir instancia anterior si existe
				const prev = (window as any).__lenis;
				if (prev) {
					prev.destroy();
					(window as any).__lenis = null;
				}

				const lenis = new Lenis({ autoRaf: true });
				(window as any).__lenis = lenis;
			}

			// Inicialización en primera carga
			createLenis();

			// Recrear después de cada View Transition
			document.addEventListener("astro:after-swap", createLenis);

			// Guardar la URL actual antes de cada navegación
			// para que las páginas de detalle puedan volver aquí con recarga completa
			document.addEventListener("astro:before-preparation", () => {
				sessionStorage.setItem("cg_prev_page", window.location.href);
			});

			// Back navigation: recarga completa solo si se vuelve a la home,
			// para evitar el cache de Astro que rompe los Swipers.
			// Para cualquier otro interior se usa history.back() normal.
			(window as any).__cgBack = () => {
				const prev = sessionStorage.getItem("cg_prev_page") || "/";
				const prevPath = new URL(prev, window.location.origin).pathname;
				const isHome = prevPath === "/" || prevPath === "/index.html";
				if (isHome) {
					window.location.href = prev;
				} else {
					history.back();
				}
			};
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
