---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import FloatingBar from "../components/helpers/FloatingBar.astro";
import CartSidebar from "../components/CartSidebar.jsx";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	canonical?: string;
}

const { title, description, ogImage, canonical } = Astro.props;

const SITE_URL = "https://goldcoronado.com";
const SITE_NAME = "Coronado Gold";
const DEFAULT_DESC = "Discover Coronado Gold's fine gold jewelry — handcrafted rings, necklaces and more. Premium 14k and 18k gold pieces crafted with precision and elegance. Shop online.";
const DEFAULT_OG_IMAGE = `${SITE_URL}/og-image.jpg`;

const pageTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;
const pageDescription = description ?? DEFAULT_DESC;
const pageImage = ogImage ?? DEFAULT_OG_IMAGE;
const pageCanonical = canonical ?? `${SITE_URL}${Astro.url.pathname}`;

const shopifyDomain = import.meta.env.SHOPIFY_DOMAIN;
const storefrontToken = import.meta.env.STOREFRONT_ACCESS_TOKEN;
---

<!doctype html>
<html lang="en" translate="no">
	<head>
		<meta charset="UTF-8" lang="en" translate="no" />
		<meta name="google" content="notranslate" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>

		<!-- SEO essentials -->
		<meta name="description" content={pageDescription} />
		<link rel="canonical" href={pageCanonical} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		<meta property="og:url" content={pageCanonical} />
		<meta property="og:image" content={pageImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter / X Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		<meta name="twitter:image" content={pageImage} />

		<!-- Per-page head content (JSON-LD, etc.) -->
		<slot name="head" />

		<!-- Inject Shopify config for client-side cart utility -->
		<script define:vars={{ shopifyDomain, storefrontToken }}>
			window.__SHOPIFY_CONFIG__ = {
				domain: shopifyDomain,
				token: storefrontToken,
			};
		</script>
	</head>
	<body>
		<Navbar />
		<FloatingBar />
		<slot />
		<Footer />

		<!-- Cart sidebar (React island, fully client-side) -->
		<CartSidebar client:load />

		<script>
			import Lenis from "lenis";
			import "lenis/dist/lenis.css";

			function createLenis() {
				const prev = (window as any).__lenis;
				if (prev) {
					prev.destroy();
					(window as any).__lenis = null;
				}

				const lenis = new Lenis({ autoRaf: true });
				(window as any).__lenis = lenis;
			}

			createLenis();

			(window as any).__cgBack = () => {
				history.back();
			};
		</script>

		<!-- Fijar altura real del viewport — evita saltos al mostrar/ocultar barra iOS -->
		<script is:inline>
			function setVh() {
				document.documentElement.style.setProperty(
					'--app-height',
					window.innerHeight + 'px'
				);
			}
			// Fijar una sola vez al cargar
			setVh();
			// Actualizar solo al rotar pantalla (no en scroll)
			window.addEventListener('orientationchange', function () {
				setTimeout(setVh, 100);
			});
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
